<script>
  // Get all elements with the megalevel class
  var megaLevelItems = document.querySelectorAll('li.megalevel');

  // Add event listeners for hover
  megaLevelItems.forEach(function(item) {
    // Get the data-megalevel value
    var megaLevelValue = item.getAttribute('data-megalevel');
    var megamenuClass = '.megamenu-' + megaLevelValue;
    var megamenu = document.querySelector(megamenuClass);

    // When the item is hovered over
    item.addEventListener('mouseenter', function() {
      if (megamenu) {
        megamenu.style.display = 'block';  // Show the corresponding megamenu
      }
    });

    // When the item is no longer hovered over
    item.addEventListener('mouseleave', function() {
      if (megamenu) {
        megamenu.style.display = 'none';  // Hide the megamenu
      }
    });
  });
</script>
<style>
  .header__logo svg { 
