}
.megamenic h4  { margin: 10px 0;  }
.megamenic a:before {display: none;}  
.megamenic h4 a , .megamenic h4   { text-transform: none; font-size: 18px; letter-spacing: 0;line-height: 1;}
 .nttrtag { background: #001e42; color: #fff; display: inline-block; padding: 3px 10px; font-size: 12px; font-weight: 600; }
/* .megamenur will act as the row */
.megamenur {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* Each column (megamenic) will take up 23-24% width for a four-column layout */
.megamenic {
  width: 24%; /* Adjust this if you need more spacing */
  box-sizing: border-box; /* Ensure padding is included in width calculation */
  padding: 10px; /* Add some padding */
  margin-bottom: 15px; /* Space between rows, if content wraps */
  text-align: left;
}
 
/* Optional responsiveness for smaller screens */
@media (max-width: 768px) {
  .megamenic {
    width: 48%; /* Switch to two columns on smaller screens */
  }
}

@media (max-width: 480px) {
  .megamenic {
    width: 100%; /* Stack the columns on very small screens */
  }

  
</style>