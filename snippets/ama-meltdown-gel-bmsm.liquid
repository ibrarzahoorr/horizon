    }
    {% endcomment %}
});

function finalSBlam() {
    var selectedVariant = document.querySelector('input[name="options[BMSM]"]:checked');
    var id = selectedVariant.getAttribute('data-id');
    addVariantToCart(selectedVariant.value)
}

function addVariantToCart(variantId) {
    var xhr = new XMLHttpRequest();
    var data = {
        id: variantId,
        quantity: 1
    };
    xhr.open('POST', '/cart/add.js', !0);
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                var item = JSON.parse(xhr.responseText);
                console.log('Variant added to cart:', item)
            } else {
                var response = JSON.parse(xhr.responseText);
                console.log('Error:', response)
            }
        }
    };
    xhr.send(JSON.stringify(data))
}
  
