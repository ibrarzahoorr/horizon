<script>

  setTimeout(function() {
    var submitCartButton = document.querySelector(".btn__dtact.btn__blue");
    if (submitCartButton) {
        var newElement = document.createElement('a');
        newElement.setAttribute('onclick', 'finalSBlam()');
        newElement.className = 'btn ml05 btn__blue bold';
        newElement.innerText = 'Add to Cart';
        submitCartButton.parentNode.replaceChild(newElement, submitCartButton);
    }
}, 3000);
window.onload = function() {
    document.querySelector(".amaatcbtn").outerHTML = '<a onclick="finalSBlam()" class="btn ml05 btn__blue bold" style="pointer-events: none;" {% if product.variants.first.available %} disabled>Out of Stock {% else %}  style="pointer-events:none" >Out of Stock  {% endif %} </button>';
    var elements = document.querySelectorAll(".product__quantity");
    elements.forEach(function(element) {
        element.style.display = "none"
    })
};
document.getElementById('select_box').addEventListener('change', function(event) {
