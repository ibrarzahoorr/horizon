  <style>ul.radio-toolbar.quantity_box{display:flex;align-items:flex-end;flex-direction:unset!important;max-width:510px;justify-content: space-between;}.radio-toolbar label{box-shadow:none!important}ul.radio-toolbar.quantity_box li:nth-of-type(3){order:1}ul.radio-toolbar.quantity_box li:nth-of-type(2){order:2}ul.radio-toolbar.quantity_box li:nth-of-type(1){order:3}.quantity_box label img{height:90px;padding-top:10px}.gr_product .product_desc ul{padding-left:0}.gr_product .product_desc ul li{background:url(/cdn/shop/files/Group_203.png?v=1608653163) no-repeat 0 -5px;list-style:none;padding-left:22px;background-size:16px;margin-bottom:8px;font-style:normal;font-weight:300;font-size:14px;line-height:145%}.gr_product .product_desc p{font-style:normal;font-weight:500;font-size:14px;line-height:145%;color:#000;margin-bottom:15px}.gr_product .product_option_wrapper,.product__sticky .product_price_lg{display:none!important}.select_box h5{font-weight:700;margin-bottom:0;margin-top:10px;font-size:15px;line-height:145%;letter-spacing:0}.select_box .quantity_box{list-style:none;padding:0;display:block}.select_box .quantity_box li{display:inline-block;width:calc(33.33% - 10px);position:relative;margin:5px}.select_box .quantity_box li:first-child{margin-left:0}.select_box .quantity_box li:last-child{margin-right:0}.radio-toolbar label{background:#ffffff;border-radius:2px;border:2px solid #f3e4dc;text-align:center;display:block;padding:0 0 10px 0}.product_box_head{display:block;border-bottom:1px solid #F8F8F8;padding:5px;float:left;width:100%;background:#f3a644;color:#fff;font-size:12px}.gr_product .box_left{text-transform:uppercase;font-size:14px;line-height:145%;color:#222;float:left}.gr_product .box_right{text-transform:uppercase;font-size:10px;line-height:145%;color:#222;float:right;padding-top:3px}.radio-toolbar input[type=radio]:checked+label,.radio-toolbar li:hover label{border-radius:2px;background:#fff5e7;display:block;box-sizing:border-box;border:2px solid #f3a644}.radio-toolbar input[type=radio]{position:absolute;width:100%;height:100%;z-index:9;opacity:0;cursor:pointer}.radio-toolbar .productname{font-weight:300;font-size:14px;line-height:145%;color:#222;display:block}.radio-toolbar .productprice_item{font-size:16px;display:block;color:#000;line-height:145%}.radio-toolbar .productprice_saving{font-weight:300;font-size:12px;display:block;line-height:145%}.gr_product .gr_button button{height:auto;font-family:'sofia-pro-bold',sans-serif;font-style:normal;font-size:18px;line-height:28px;text-align:center;letter-spacing:.5px;width:100%;max-width:100%;margin-bottom:0}.gr_product .disclaimer-under-form span{font-weight:500;font-size:12px;align-items:center;letter-spacing:.01em;color:#000}.gr_product .price-item.price-item--regular{display:none}@media (min-width:46.85em){.product.gr_product{max-width:1400px;grid-template-columns:0.5fr .6fr}}@media (max-width:1057px){.radio-toolbar .productname { font-size: 11px;}.product.gr_product{grid-template-columns:0.4fr .6fr}.gr_product .product__content--information{max-width:99%}.select_box .quantity_box li{width:calc(33.33% - 10px);margin:3px}}@media (min-width:37.5em){.product__description .btn{max-width:490px!important}}.product__quantity,.size-selector.js-options{display:none!important}</style> 
<script>setTimeout(function() { var submitCartButton = document.querySelector(".js-submit-cart.btn__blue"); if (submitCartButton) { var newElement = document.createElement('a'); newElement.setAttribute('onclick', 'finalSBlam()'); newElement.className = 'btn ml05 btn__blue bold'; newElement.innerText = 'Add to Cart'; submitCartButton.parentNode.replaceChild(newElement, submitCartButton); } }, 3000); window.onload=function(){document.querySelector(".js-submit-cart").outerHTML='<a onclick="finalSBlam()" class="btn ml05 btn__blue bold" >Add to Cart</button>';var elements=document.querySelectorAll(".product__quantity");elements.forEach(function(element){element.style.display="none"})};document.getElementById('select_box').addEventListener('change',function(event){if(event.target.type==='radio'){var selectedValue=event.target.value}});function finalSBlam(){var selectedVariant=document.querySelector('input[name="options[BMSM]"]:checked');var id=selectedVariant.getAttribute('data-id');addVariantToCart(selectedVariant.value)}
function addVariantToCart(variantId){var xhr=new XMLHttpRequest();var data={id:variantId,quantity:1};xhr.open('POST','/cart/add.js',!0);xhr.setRequestHeader('Content-Type','application/json');xhr.onreadystatechange=function(){if(xhr.readyState===4){if(xhr.status===200){var item=JSON.parse(xhr.responseText);console.log('Variant added to cart:',item)}else{var response=JSON.parse(xhr.responseText);console.log('Error:',response)}}};xhr.send(JSON.stringify(data))}
document.getElementById('select_box').addEventListener('change', function(event) {
    if (event.target.type === 'radio') {
        var selectedValue = event.target.getAttribute('data-variant-price')
    }
  console.log(selectedValue);
    
});
</script>
 