<div class='account__address bg-w bggl rel px15 {{ className }}'>
  {% if default %}
    <h6 class='address__default pv025 ph05 mx0 abs right small bgw caps mr1'>Default</h6>
  {% endif %}
  <div class='al'>
    <h6>
      <div class='medium mb1'>{{ address.name }}</div>
      {% if address.company %}{{ address.company }}<br />{% endif %}
      {{ address.street }}<br />
      {{ address.city | capitalize }}{% if address.province %}, {{ address.province | upcase }} {% endif %} {{ address.zip | upcase }}<br />
      {{ address.country }}<br />
      {% if address.phone != '' %}{{ address.phone }}{% endif %}
    </h6>
  </div>

  {% if edit %}
    <div class='address__footer mt05'>
      <button class='btn btn__small link--underline mr05 caps track medium' onclick='slater.toggleForm({{address.id}})'>Edit</button>
      <button class='btn btn__small link--underline mr05 caps track medium' onclick='slater.removeAddress({{address.id}})'>Delete</button>
    </div>
  {% endif %}
</div>
