<script>
function finalSBlam() {
    var t = document.querySelector('input[name="options[BMSM]"]:checked');
    t.getAttribute("data-id"), addVariantToCart(t.value)
}

function addVariantToCart(variantId) {
     
    const cartData = {
      items: [
        {
          id: variantId,
          quantity: 1
        }
      ]
    }; 
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(cartData)
    })
    .then(response => response.json())
    .then(data => {
      console.log('Item added to cart:', data); 
      //window.location.href = '/cart';
    })
    .catch(error => {
      console.error('Error adding item to cart:', error); 
    });
  }
setTimeout(function() {
    var t = document.querySelector(".js-submit-cart.btn__blue");
    if (t) {
        var e = document.createElement("a");
        e.setAttribute("onclick", "finalSBlam()"), e.className = "btn btn_dynctabt ml05 btn__blue bold", e.innerText = "Add to Cart", t.parentNode.replaceChild(e, t)
    }
}, 3e3), window.onload = function() {
    document.querySelector(".js-submit-cart").outerHTML = '<a onclick="finalSBlam()" class="btn ml05 btn__blue bold" {% if product.variants.first.available %}>Add to Cart {% else %}  style="pointer-events:none" >Out of Stock  {% endif %}</button>', document.querySelectorAll(".product__quantity").forEach(function(t) {
        t.style.display = "none"
    })
}, document.getElementById("select_box").addEventListener("change", function(t) {
    "radio" === t.target.type && t.target.value
});
</script>

