<script>
document.addEventListener("DOMContentLoaded", function() {
    // Countdown timer until midnight
    function updateTimer() {
        var now = new Date();
        var midnight = new Date();
        midnight.setHours(24, 0, 0, 0); // Set time to midnight
        var diff = midnight - now; // Difference in milliseconds

        var hours = Math.floor(diff / (1000 * 60 * 60));
        var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        var seconds = Math.floor((diff % (1000 * 60)) / 1000);

        document.getElementById("order-timer").textContent =
            ("0" + hours).slice(-2) + " : " +
            ("0" + minutes).slice(-2) + " : " +
            ("0" + seconds).slice(-2);
    }

    setInterval(updateTimer, 1000);

    // Shipping date
    var daysAfterToday = 16;
    var today = new Date();
    var shipDate = new Date(today.setDate(today.getDate() + daysAfterToday));
  var options = { weekday: 'long' };
    var formattedShipDate = shipDate.toLocaleDateString('en-US', options);
    //document.getElementById('shipping-date').textContent = formattedShipDate;
});
