<style>
    .bm-pickplan-x91 {
  --bm-bg:rgb(15, 11, 7);
  --bm-surface: #fffaf6;
  --bm-surface-2: #ffffff;
  --bm-text: #2f241f;
  --bm-muted: #7b6d66;
  --bm-border: #e6d8cf;
  --bm-accent:rgb(25, 64, 123);
  --bm-accent-deep: #061c3d;
  --bm-accent-soft: #f7ded5;
  --bm-highlight: #ae59ca;
  --bm-slate: #6d7d86;
  --bm-success: #5b9a6a;
  --bm-shadow: 0 10px 30px rgba(68, 41, 28, 0.08);
  margin:  0 0 2rem 0;
  color: var(--bm-text);
  font-family: inherit;
}

.bm-pickplan-x91 *,
.bm-pickplan-x91 *::before,
.bm-pickplan-x91 *::after {
  box-sizing: border-box;
}

.bm-pickplan-x91__shell {
  display: grid;
  gap: 1rem;
}

.bm-pickplan-x91__choice {
  border: 1px solid var(--bm-border);
  border-radius: 4px;
  background: var(--bm-surface-2);
  padding: 1.15rem;
  box-shadow: var(--bm-shadow);
  transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
}

.bm-pickplan-x91__choice.is-active {
  border-color: var(--bm-accent);
  background: var(--bm-surface);
  box-shadow: 0 12px 36px rgba(97, 55, 35, 0.11);
}

.bm-pickplan-x91__top {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  width: 100%;
  cursor: pointer;
}

.bm-pickplan-x91__top-main {
  display: flex;
  align-items: flex-start;
  gap: 0.9rem;
  flex: 1 1 auto;
}

.bm-pickplan-x91__plan-radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.bm-pickplan-x91__radio-ui {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1.5px solid #bcaea6;
  background: #fff;
  position: relative;
  flex: 0 0 auto;
  margin-top: 0.1rem;
}

.bm-pickplan-x91__choice.is-active .bm-pickplan-x91__radio-ui {
  border-color: var(--bm-accent);
}

.bm-pickplan-x91__choice.is-active .bm-pickplan-x91__radio-ui::after {
  content: "";
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: var(--bm-accent);
}

.bm-pickplan-x91__heading-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.bm-pickplan-x91__heading {
  font-size: 1.15rem;
  line-height: 1.1;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--bm-text);
  font-weight: 700;
}

.bm-pickplan-x91__choice:not(.is-active) .bm-pickplan-x91__heading {
  opacity: 0.58;
}

.bm-pickplan-x91__pill {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  min-height: 28px;
  padding: 0.4rem 0.75rem;
  border-radius: 999px;
  font-size: 0.78rem;
  line-height: 1;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.bm-pickplan-x91__pill--accent {
  background: var(--bm-highlight);
  color: #ffffff;
}

.bm-pickplan-x91__pill--muted {
  background: var(--bm-slate);
  color: #ffffff;
}

.bm-pickplan-x91__pricebox {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.3rem;
  text-align: right;
  white-space: nowrap;
}

.bm-pickplan-x91__was {
  color: #a8968d;
  text-decoration: line-through;
  font-size: 1rem;
  line-height: 1;
}

.bm-pickplan-x91__now {
  color: var(--bm-text);
  font-weight: 800;
  font-size: 1.45rem;
  line-height: 1;
}

.bm-pickplan-x91__now--sub {
  color: var(--bm-accent-deep);
}

.bm-pickplan-x91__perk-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem 1.5rem;
  padding-top: 1rem;
}

.bm-pickplan-x91__perk-col {
  display: grid;
  gap: 0.55rem;
}

.bm-pickplan-x91__perk {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  color: var(--bm-text);
  font-size: 0.98rem;
  line-height: 1.35;
}

.bm-pickplan-x91__choice:not(.is-active) .bm-pickplan-x91__perk {
  opacity: 0.58;
}

.bm-pickplan-x91__perk strong {
  text-transform: uppercase;
  font-weight: 800;
}

.bm-pickplan-x91__perk-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--bm-accent-soft);
  color: var(--bm-accent-deep);
  font-size: 0.7rem;
  line-height: 1;
  font-weight: 800;
  flex: 0 0 auto;
  margin-top: 0.1rem;
}

.bm-pickplan-x91__group {
  padding-top: 1rem;
}

.bm-pickplan-x91__group--hidden {
  display: none;
}

.bm-pickplan-x91__label {
  margin-bottom: 0.8rem;
  font-size: 0.95rem;
  line-height: 1.2;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--bm-text);
  font-weight: 700;
}

.bm-pickplan-x91__option-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
}

.bm-pickplan-x91__tile,
.bm-pickplan-x91__mini-tile {
  position: relative;
  display: block;
  width: 100%;
  cursor: pointer;
}

.bm-pickplan-x91__tile input,
.bm-pickplan-x91__mini-tile input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.bm-pickplan-x91__tile-title,
.bm-pickplan-x91__mini-text {
  display: block;
}

.bm-pickplan-x91__tile > span:not(input) {
  pointer-events: none;
}

.bm-pickplan-x91__tile {
  border: 1px solid var(--bm-border);
  border-radius: 18px;
  background: #fff;
  padding: 1rem 0.65rem 0.7rem;
  text-align: center;
  min-height: 78px;
  transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
}

.bm-pickplan-x91__tile:hover {
  transform: translateY(-1px);
}

.bm-pickplan-x91__tile:has(input:checked) {
  border-color: var(--bm-accent);
  background: #fff4ef;
}

.bm-pickplan-x91__save-tag {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translate(-50%, -50%);
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 0.22rem 0.55rem;
  border-radius: 999px;
  background: var(--bm-highlight);
  color: #fff;
  font-size: 0.72rem;
  line-height: 1;
  text-transform: uppercase;
  font-weight: 700;
  white-space: nowrap;
}

.bm-pickplan-x91__save-tag--slate {
  background: var(--bm-slate);
