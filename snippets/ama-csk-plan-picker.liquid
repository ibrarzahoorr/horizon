</style>
<script>
  (function () {
    var root = document.querySelector('[data-bm-plan-root]');
    if (!root) return;

    var modeRadios = root.querySelectorAll('input[name="bm_purchase_mode_x91"]');
    var choices = root.querySelectorAll('.bm-pickplan-x91__choice');
    var subChoice = root.querySelector('.bm-pickplan-x91__choice--sub');
    var oneChoice = root.querySelector('.bm-pickplan-x91__choice--one');
    var oneWrap = root.querySelector('[data-bm-one-wrap]');
    var deliveryRadios = root.querySelectorAll('input[name="bm_delivery_x91"]');
    var sellingPlanInput = root.querySelector('[data-bm-selling-plan]');
    var variantInput = root.querySelector('[data-bm-variant-id]');

    function getSelectedMode() {
      var checked = root.querySelector('input[name="bm_purchase_mode_x91"]:checked');
      return checked ? checked.value : 'subscription';
    }

    function getActiveVariantRadio() {
      var mode = getSelectedMode();
      if (mode === 'onetime') {
        return root.querySelector('input[name="bm_variant_one_x91"]:checked');
      }
      return root.querySelector('input[name="bm_variant_sub_x91"]:checked');
    }

    function getSelectedDeliveryPlan() {
      var checked = root.querySelector('input[name="bm_delivery_x91"]:checked');
      return checked ? checked.value : '';
    }

    function syncState() {
      var mode = getSelectedMode();
      root.setAttribute('data-bm-mode', mode);

      choices.forEach(function (item) {
        item.classList.remove('is-active');
      });

      if (mode === 'subscription') {
        subChoice.classList.add('is-active');
        if (oneWrap) oneWrap.style.display = 'none';
        if (sellingPlanInput) {
          sellingPlanInput.value = getSelectedDeliveryPlan();
        }
      } else {
        oneChoice.classList.add('is-active');
        if (oneWrap) oneWrap.style.display = 'block';
        if (sellingPlanInput) {
          sellingPlanInput.value = '';
        }
      }

      var activeVariant = getActiveVariantRadio();
      if (activeVariant && variantInput) {
        variantInput.value = activeVariant.getAttribute('data-variant-id') || '';
      }
    }

    modeRadios.forEach(function (radio) {
      radio.addEventListener('change', syncState);
    });

    deliveryRadios.forEach(function (radio) {
      radio.addEventListener('change', syncState);
    });

    root.querySelectorAll('input[name="bm_variant_sub_x91"], input[name="bm_variant_one_x91"]').forEach(function (radio) {
      radio.addEventListener('change', syncState);
    });

    syncState();
  })();
</script>