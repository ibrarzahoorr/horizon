{% if listId %}
  {% assign list = listId %}
{% else %}
  {% assign list = 'JSkLcF' %}
{% endif %}

{% comment %} Add Retention Science in here {% endcomment %}
{% form 'customer', id: 'email_signup', name: 'mc-embedded-subscribe-form', class: 'validate' %}
  {{ form.errors | default_errors }}
  {% if form.posted_successfully? %}
    <p class="form--success">Thanks for signing up! We'll be in touch soon</p>
  {% else %}
    <div class="newsletter__form container--s rel f aic">
      <input type="hidden" id="contact_tags" name="contact[tags]" value="prospect,newsletter">
      <input type="email" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="Your Email" name="contact[email]" id="contact_email" class="abs fill-x fill-y newsletter__input" autocorrect="off" autocapitalize="off">
      <button type="submit" class="newsletter__submit abs right" name="commit" id="Subscribe">
        <span class="caps cdb black ls1">Submit</span>
      </button>
    </div>
  {% endif %}
{% endform %}

{% comment %} <form action="https://manage.kmail-lists.com/subscriptions/subscribe?a=Kg5iBx&g={{list}}" method="POST" id="email_signup" name="mc-embedded-subscribe-form" class="validate" target="_blank" novalidate>
  {{ form.errors | default_errors }}
