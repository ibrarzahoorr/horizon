<script>
  var acc = document.getElementsByClassName("accordionc");
  var i;

  for (i = 0; i < acc.length; i++) {
    acc[i].addEventListener("click", function() {
      this.classList.toggle("active");
      var panel = this.nextElementSibling;

      if (panel.style.maxHeight) {
        panel.style.maxHeight = null;
      } else {
        panel.style.maxHeight = panel.scrollHeight + "px";
      }
    });
  }
</script>

<style>
  .lazyloadxx {
    width: 100%;
    display: block;
  }

  .accordionc {
    background: transparent;
    cursor: pointer;
    padding: 10px 18px 18px;
    width: 100%;
    border: none;
    text-align: left;
    outline: none;
    font-size: 16px;
    transition: 0.4s;
    border-bottom: 1px solid #333;
    font-weight: 600;
    letter-spacing: 0;
  }

  .active,
  .accordionc:hover {
    color: rgb(49, 49, 49);
  }

  .accordionc:after {
    content: '\002B';
    color: #000;
    font-weight: bold;
    float: right;
    margin-left: 5px;
  }

  .active:after {
    content: "\2212";
  }

  .panel {
    padding: 0 18px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease-out;
    margin-top: 10px;
    text-align: left;
  }
  .panel p {    font-size: 15px; }
</style>
          


  
