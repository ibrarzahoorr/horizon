{% comment %}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const media = document.getElementById("srm-media");
    const content = document.getElementById("srm-content");

    if (!media || !content) return;

    function syncMinHeight() {
      media.style.minHeight = content.offsetHeight + "px";
    }

    syncMinHeight();
    window.addEventListener("resize", syncMinHeight);
  });
</script>
{% endcomment %}

