{% assign tag = tag | default: 'a' %}

{% capture cx %}
  rel
  {{ className }}
  {% if outline == true %}button--outline{% endif %}
  {% if small == true %}button--small{% endif %}
  {% if light == true %}button--light{% endif %}
  {% if inherit == true %}button--inherit{% endif %}
{% endcapture %}

<{{ tag }}
  {% if href %}href='{{ href }}'{% endif %}
  {% if type %}type='{{ type }}'{% endif %}
  {% if name %}name='{{ name }}'{% endif %}
  class='{% include 'u-cx' with cx %}'
  {% if onclick %}onclick={{onclick}}{% endif %}
  role='button'>
  {{ cta }}
</{{ tag }}>
