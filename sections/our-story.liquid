  <div class='abs cb our__story_shape_one'>
    {% include 'shape-two' %}
  </div>
  <div class='abs fill-x fill-y chp our__story_shape_two'>
    {% include 'shape-one' %}
  </div>
  <div class='abs fill-x fill-y cp our__story_shape_three'>
    {% include 'shape-four' %}
  </div>
  <div class='abs fill-x fill-y cb our__story_shape_four'>
    {% include 'shape-three' %}
  </div>
</div>

