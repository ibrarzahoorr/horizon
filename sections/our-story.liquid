            <p class='pb0 mb0 our__story_block_text'>{{ section.settings.about_description_2 }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class='px1 pm60 pl100 pt160 o-h rel our__story_block js-our-story'>
    <div class='container--xl mha rel z2'>
      <div class='f fw jcb aic our__story_flex odd'>
        <div class='container--m mha fill-x our__story_medium_clear'>
          <div class='container--s ac mha our__story_flex_image right'>
            <img class='fill-x lazyload' data-src="{{ section.settings.about_image_3 | img_url: '1200x' }}" />
          </div>
        </div>
        <div class='container--m mha'>
          <div class='container--s ph1 mha'>
            <h3 class='serif mx0 px0 pt05 our__story_block_text'>{{ section.settings.about_title_3 }}</h3>
            <p class='pb0 mb0 our__story_block_text'>{{ section.settings.about_description_3 }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class='bg-lp px1 m60 pl100 pbl160 o-h rel our__story_block js-our-story'>
    <div class='container--xl mha rel z2'>
      <div class='f fw jcb aic our__story_flex'>
        <div class='container--m mha fill-x our__story_medium_clear'>
          <div class='container--s ac mha our__story_flex_image left'>
            <img class='fill-x lazyload' data-src="{{ section.settings.about_image_4 | img_url: '1200x' }}" />
