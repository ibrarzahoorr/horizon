<div class='bg-lp rel o-h pb2 our__story' data-module='ourStory'>
  <section class='bg-lp pm60 pl100 px1 ptl160 rel our__story_block js-our-story'>
    <div class='container--xl mha  rel z2'>
      <div class='f fw jcb aic our__story_flex odd'>
        <div class='container--m mha fill-x our__story_medium_clear'>
          <div class='container--s ac mha our__story_flex_image ar'>
            <img class='fill-x lazyload' data-src="{{ section.settings.about_image_1 | img_url: '1200x' }}" />
          </div>
        </div>
        <div class='container--m mha fill-x'>
          <div class='container--s ph1 mha'>
            <h3 class='serif mx0 px0 pt05 our__story_block_text'>{{ section.settings.about_title_1 }}</h3>
            <p class='pb0 mb0 our__story_block_text'>{{ section.settings.about_description_1 }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class='pm60 px1 pl100 ptl160 o-h rel our__story_block js-our-story'>
    <div class='container--xl mha rel z2'>
      <div class='f fw jcb aic our__story_flex'>
        <div class='container--m mha fill-x our__story_medium_clear'>
          <div class='container--s ac mha our__story_flex_image left'>
            <!-- <div class='our__story_background abs fill-x fill-y fit' style='background-image: url({{ section.settings.about_image_2 | img_url: '1200x' }})'></div> -->
            <img class='fill-x lazyload' data-src="{{ section.settings.about_image_2 | img_url: '1200x' }}" />
          </div>
        </div>
        <div class='container--m mha'>
