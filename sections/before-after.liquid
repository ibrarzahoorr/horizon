<section class="bg-lp before-after">
  <h2 class="outline caps heading">{{ section.settings.heading }}</h2>
  <p class="mx0 h5 pb0 mb0">{{ section.settings.subheading }}</p>

  <div class="fill-x fill-y rel  pv2" data-module='beforeAndAfter'>
    <div class="js-before-slides bna-slider collection__slideshow fill-x">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
              <div>
                <div class="bna-card bg-w">
                  {% if block.settings.image_single %}
                      <div class="fill-x rel bna-image"> 
                          <img class="lazyload" data-src="{{ block.settings.image_single | img_url: '1000x' }}" data-srcset="{{ block.settings.image_after | img_url: '2000x' }} 2x">
                      </div>
                  {% else %}
                  <div class="bna-images">                   
                      <div class="fill-x rel bna-image">  
                        <img class="lazyload" data-src="{{ block.settings.image_before | img_url: '900x' }}" data-srcset="{{ block.settings.image_before | img_url: '1200x' }} 2x">       
                      </div>
                      <div class="fill-x rel bna-image"> 
                          <img class="lazyload" data-src="{{ block.settings.image_after | img_url: '900x' }}" data-srcset="{{ block.settings.image_after | img_url: '1200x' }} 2x">
                      </div>
                  </div>
                  {% endif %}
                  <div class="bna-text bg-w ac">
                    <div>
                      <div class="serif h5 bna-headline">
                        {{ block.settings.headline }}
                      </div>
                      <div>
                        {{ block.settings.paragraph }}
                      </div>
                     </div>
                      <div class="bna-name">
                        {{ block.settings.name }}
                      </div>
                  </div>
                  </div>
              </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>


{% schema %}
  {
    "name": "Before And After",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "ACNE PRONE SKIN"
      }, {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Beautiful Before and Beautiful After"
      }
    ],
    "max_blocks": 6,
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "image_before",
            "label": "Image Before"
          },
          {
            "type": "image_picker",
            "id": "image_after",
            "label": "Image After"
          },
          {
            "type": "image_picker",
            "id": "image_single",
            "label": "Sinlge Image"
          },
          {
            "type": "text",
            "id": "headline",
            "label": "Headline",
            "default": "I am absolutely in love!"
          },
          {
            "type": "richtext",
            "id": "paragraph",
            "label": "Paragraph"
          }, {
            "type": "text",
            "id": "name",
            "label": "Name"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Before And After"
      }
    ]
  }
{% endschema %}