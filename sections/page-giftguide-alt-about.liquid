{% include 'page-holiday-about' with 
  heading: section.settings.heading,
  description: section.settings.description,
  image: section.settings.image,
  bullet_type: section.settings.bullet_type,
  props: section.blocks
%}

{% schema %}
  {
    "name": "About",
    "settings": [
      {
        "type": "header",
        "content": "Settings"
      },
      {
        "type": "select",
        "id": "bullet_type",
        "label": "Bullet Type",
        "options": [
          { "label": "Cross", "value": "cross" },
          { "label": "Tick", "value": "tick" }
        ],
        "default": "cross"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }
    ],
    "blocks": [
      {
        "type": "value_prop",
        "name": "Value Prop",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          }
        ]
      }
    ]
  }
{% endschema %}