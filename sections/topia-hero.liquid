<section class='topia rel ac' data-module='topiaHero'>
  <div class='topia__hero rel js-topia-hero'>
    <div class='abs x y top left topia__background-loading bg-p z3'></div>
    <div class='plane js-plane'>
      <video class='x y top left' muted autoplay loop poster='{{section.settings.image | img_url: "2048x2048" }}'>
        <source src='{{ 'water_f.static.mp4' | asset_url }}' type='video/mp4'>
      </video>
    </div>
    <div class='abs x y top left cw f jcc aic z2'>
      <div class='topia__logo x container--xl ma px1'>
        {% include 'blumetopia' %}
      </div>
    </div>
  </div>
  <div class='topia__tree-left abs  left bottom'>
    <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/palm_left.png?50389' alt='palm tree' />
  </div>
  <div class='topia__tree-right abs  right bottom'>
    <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/palm-right.png?50389' alt='palm tree' />
  </div>
  <div class='topia__babe x jcc f aic rel'>
    <div class='container--s px1'>
      {% if section.settings.icon %}
        <img class='topia__babe-icon lazyload' data-src='{{section.settings.icon | img_url: "188x188" }}' />
      {% endif %}
      <h3 class='cooper h2 mb05 js-hero-desc'>{{section.settings.heading}}</h3>
      <p class='s22 mt0'>{{section.settings.subheading}}</p>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Topia Hero",
    "settings": [

      {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Are you a Blume Babe?"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Let’s make it official. Join our loyalty program today and earn merch, points and more on the way to Blumetopia."
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Background Image"
      }
    ],
    "presets": [{
      "name": "Topia Hero",
      "category": "Hero"
    }]
  }
{% endschema %}
