<section class="page__holiday-hero bg-lb px2 pm100 pl100 ptl160 o-h rel hero hero__tall tallest rel" id="top" data-module="hero">
  <div class="holiday-hero__container">
    <div class='abs fill-y hero__image_background desktop show__tablet' style="background-image: url({{ section.settings.desktop_image | img_url: '1800x' }})"></div>
    <div class='abs fill-x fill-y fill hero__image_background mobile hide__tablet' style="background-image: url({{ section.settings.mobile_image | img_url: '1200x' }});"></div>
    <div class='holiday-hero__content-container container--l mha rel fill-y f ais jcb z2 pv2'>
      <div class="holiday-hero__content text-box">
        <h1 class="mt0 mb0 serif">{{ section.settings.heading }}</h1>
        <p class="container--ms">{{ section.settings.description }}</p>
      </div>
    </div>
  </div>
  <div class='abs left fill-x fill-y clp collection__bar'>
    <svg width="3253" height="1282" viewBox="0 0 3253 1282" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3253 1282H0V497.186C0 497.186 567.527 93.2737 1484.62 184.904C2266 262.974 3253 0 3253 0V1282Z" fill="#FBECE3"/>
    </svg>
  </div>
</section>

{% schema %}
  {
    "name": "Hero",
    "settings": [
      {
        "type": "header",
        "content": "Image"
      },
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "text",
        "id": "description",
        "label": "Description"
      }
    ]
  }
{% endschema %}