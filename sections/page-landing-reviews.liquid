<div class="page-landing__reviews bg-w px2">
  <div class="container--l px1" style="margin: 0 auto;">
    {%- assign product = all_products[section.settings.product] %}
    {% if section.settings.heading != blank %}
      <h2 class="section-heading serif mt0 ac">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="landing-reviews__container container--m rel">
      <div class="reviews-slideshow container--s js-reviewsSlideshow">
        {% for block in section.blocks %}
          <div class="review ac js-slide">
            <div class="review-top mb1">
              <p class="mb0 caps bold small">{{ block.settings.author }}</p>
              <div class="stars">
                {% assign score = block.settings.rating %}
                {% for i in (1..5) limit: score %}
                  <span class="star">&#9733;</span>
                {% endfor %}
              </div>
            </div>
            <h4 class="serif mt0 mb0">{{ block.settings.heading }}</h4>
            <p class="mb0">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
      <div class="navigation-arrows">
        <div class="nav-arrow js-slideshowNav prev abs left"></div>
        <div class="nav-arrow js-slideshowNav next abs right"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Reviews",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Not to brag, but people are loving us"
      }
    ],
    "blocks": [
      {
        "type": "review",
        "name": "Review",
        "settings": [
          {
            "type": "range",
            "id": "rating",
            "label": "Rating",
            "min": 1,
            "max": 5,
            "step": 1,
            "default": 5,
            "unit": "rev"
          },
          {
            "type": "text",
            "id": "author",
            "label": "Author"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "textarea",
            "id": "description",
            "label": "Description"
          }
        ]
      }
    ]
  }
{% endschema %}