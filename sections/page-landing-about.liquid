<div class="page-landing__about" style="background-color: {{ section.settings.bg_color }};">
  <div class="landing-about__container f rel">
    <div class="landing-hiw__image">
      <img class="desktop-image lazyload" data-src="{{ section.settings.desktop_image | img_url: '1000x' }}" data-srcset="{{ section.settings.desktop_image | img_url: '2000x' }} 2x">
      <img class="mobile-image lazyload" data-src="{{ section.settings.mobile_image | img_url: '400x' }}" srcset="{{ section.settings.mobile_image | img_url: '800x' }} 2x">
    </div>
    <div class="landing-about__content container--ms f jcc px2">
      <div class="landing-about__text">
        {% if section.settings.heading != blank %}
          <h2 class="serif al mt0">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="mt0">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <ul class="landing-about__list">
          {% for block in section.blocks %}
            <li>
              <img src="{{ section.settings.bullet | img_url: '24x' }}">
              {{ block.settings.text }}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "About",
    "settings": [
      {
        "type": "header",
        "content": "settings"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color"
      },
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description"
      },
      {
        "type": "image_picker",
        "id": "bullet",
        "label": "Bullet",
        "info": "Upload a png of the icon used for the bullet of each prop."
      }
    ],
    "blocks": [
      {
        "type": "prop",
        "name": "List Item",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          }
        ]
      }
    ]
  }
{% endschema %}