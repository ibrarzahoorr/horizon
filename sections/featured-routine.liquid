<section class="modern-section" style="background: {{ section.settings.bg_color }};">
  <div class="modern-container">
    <div class="routine-split">
      <div class="routine-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      
      <div class="routine-content">
        {%- if section.settings.tag != blank -%}
          <span class="routine-tag">{{ section.settings.tag }}</span>
        {%- endif -%}
        
        <h2 class="modern-title">{{ section.settings.title }}</h2>
        
        {%- if section.settings.text != blank -%}
          <div class="modern-subtitle">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <ul class="routine-steps">
          {%- for block in section.blocks -%}
            <li class="routine-step" {{ block.shopify_attributes }}>
              <span class="step-num">{{ forloop.index }}</span>
              <div>
                <strong style="display: block;">{{ block.settings.title }}</strong>
                <span class="modern-subtitle" style="font-size: 14px; margin: 0;">{{ block.settings.text }}</span>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="modern-btn">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Routine",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Routine Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "The Essentials"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Everything you need for glowy skin."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>A simple, effective routine designed to transform your skin in 30 days.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop the Bundle"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Routine Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Cleanse"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Step Description",
          "default": "Remove impurities without stripping."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Routine",
      "blocks": [
        { "type": "step", "settings": { "title": "Cleanse", "text": "Gentle daily cleanser" } },
        { "type": "step", "settings": { "title": "Tone", "text": "Balance your skin pH" } },
        { "type": "step", "settings": { "title": "Moisturize", "text": "Lock in hydration" } }
      ]
    }
  ]
}
{% endschema %}
