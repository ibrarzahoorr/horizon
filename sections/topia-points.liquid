<section class='container--xl mxa px1'>
  <div class='f jcb aie fw'>
    {% if section.settings.image %}
      <div class='topia__points-image ar x'>
        <img class='pt1 mb15 x pb1 lazyload' data-src='{{section.settings.image | img_url: "608x608" }}' />
        {% if section.settings.icon %}
        <div class='topia__rainbow ar x mt1 pt1'>
          <img class='topia__rainbow-icon pt1 lazyload' data-src='{{section.settings.icon | img_url: "188x188" }}' />
        </div>
        {% endif %}
      </div>
    {% endif %}
    <div class='topia__points-box' data-module='topiaBox'>
      <div class='topia__box-wrapper contained topia__box-right rel'>
        <div class='topia__box rel z3'>
          <div class='topia__box-header px1 f x aic jcb bgtb'>
            <div class='topia__box-lines rel pr1'></div>
            <h5 class='mono caps mx0 px0 pl1'>Get Points</h5>
          </div>
          <div class='topia__box-content bg-w'>
            <div class='topia__box-inner px15'>
              {{section.settings.Description}}
              <a href='#smile-home' class='caps js-open-smile no-ajax btn btn__topia rel'>
                <span class='rel z2'>Take me to Blumetopia</span>
                <video class='abs x y top left' muted autoplay loop>
                  <source src='{{ 'button_water.static.mp4' | asset_url }}' type='video/mp4'>
                </video>
              </a>
            </div>
          </div>
        </div>
        <div class='topia__box-two z2 abs x y top left bgty'></div>
        <div class='topia__box-three z1 abs x y top left bgtp'></div>
      </div>
    </div>
    {% if section.settings.icon %}
      <div class='topia__rainbow ar x mt1 pt1'>
        <img class='topia__rainbow-icon pt1 lazyload' data-src='{{section.settings.icon | img_url: "188x188" }}' />
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
  {
    "name": "Topia Points",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Get Points"
      },
      {
        "type": "richtext",
        "id": "Description",
        "label": "description",
        "default": "<p>It’s completely free and you earn Blume Bucks right away with our welcome offer. If you already have an account, sign in earn Blume Bucks! You can earn BB by shopping your favourite products, leaving a product review or by following us on our social channels, the opportunities are endless! The more Blume Bucks, the greater the reward.</p>"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Paired Image"
      },
      {
      "type": "image_picker",
      "id": "icon",
      "label": "Paired Icon"
      }
    ],
    "presets": [{
      "name": "Topia Points",
      "category": "Topia"
    }]
  }
{% endschema %}
