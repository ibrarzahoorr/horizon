<script>
  (function() {
    const mediaData = [
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/18c0ee463ab54d1cb466959ae27722b0.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/18c0ee463ab54d1cb466959ae27722b0.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/7f2c33b6ae9f4ecbbdf5c87d087ce85f.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/7f2c33b6ae9f4ecbbdf5c87d087ce85f.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/fb2e2fbc634c43e1a6bf60237be06908.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/fb2e2fbc634c43e1a6bf60237be06908.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/912cb0612b014882a5d776f9de4fadb2.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/912cb0612b014882a5d776f9de4fadb2.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/2c2a974b9fe6402dbb76f5e15d14d1a1.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/2c2a974b9fe6402dbb76f5e15d14d1a1.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/b977b086966f466fb8a79082694593d4.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/b977b086966f466fb8a79082694593d4.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/94b2e3e2286340d5943b2810a30ae861.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/94b2e3e2286340d5943b2810a30ae861.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/66e3dd98dc474d20835f830d7d66a8b1.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/66e3dd98dc474d20835f830d7d66a8b1.png?v=1769050864'
      },
      {
        video: 'https://cdn.shopify.com/videos/c/o/v/87a3ff79a4f742428fb8de65232bfe08.mp4',
        poster: 'https://cdn.shopify.com/s/files/1/0003/4580/0755/files/87a3ff79a4f742428fb8de65232bfe08.png?v=1769050864'
      }
    ];

    const track = document.getElementById('cskf_vid_track');
    const prevBtn = document.getElementById('cskf_vid_prev');
    const nextBtn = document.getElementById('cskf_vid_next');
    const dotsContainer = document.getElementById('cskf_vid_dots');
    
    let currentIndex = 0;
    let slidesToShow = 5;

    function updateSlidesToShow() {
      if (window.innerWidth <= 768) slidesToShow = 1;
      else if (window.innerWidth <= 1024) slidesToShow = 3;
      else slidesToShow = 5;
    }

    function createSlides() {
      track.innerHTML = '';
      mediaData.forEach(({ poster, video }, index) => {
        const slide = document.createElement('div');
        slide.className = 'cskf_vid_slide';
        slide.innerHTML = `
          <div style="position: relative;">
            <img class="cskf_vid_poster" 
                 src="${poster}" 
                 data-video="${video}" 
                 alt="Customer review video"
                 loading="lazy">
            <div class="cskf_play_icon"></div>
          </div>
          <video src="${video}" muted preload="none" style="display: none;"></video>
        `;
        track.appendChild(slide);
      });
    }

    function createDots() {
      dotsContainer.innerHTML = '';
      const maxDots = Math.ceil(mediaData.length / slidesToShow);
      for (let i = 0; i < maxDots; i++) {
        const dot = document.createElement('button');
        dot.className = 'cskf_vid_dot';
        dot.addEventListener('click', () => goToSlide(i));
        dotsContainer.appendChild(dot);
      }
      updateDots();
    }

    function updateDots() {
      const dots = dotsContainer.querySelectorAll('.cskf_vid_dot');
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === Math.floor(currentIndex / slidesToShow));
      });
    }

    function goToSlide(index) {
      currentIndex = Math.max(0, Math.min(index * slidesToShow, mediaData.length - slidesToShow));
      updateCarousel();
    }

    function nextSlide() {
      currentIndex = currentIndex < mediaData.length - slidesToShow ? currentIndex + slidesToShow : 0;
      updateCarousel();
    }

    function prevSlide() {
      currentIndex = currentIndex > 0 ? currentIndex - slidesToShow : Math.max(0, mediaData.length - slidesToShow);
      updateCarousel();
    }

    function updateCarousel() {
      const translateX = -(currentIndex * (100 / slidesToShow));
      track.style.transform = `translateX(${translateX}%)`;
      updateDots();
    }

    // Event listeners
    prevBtn.addEventListener('click', prevSlide);
    nextBtn.addEventListener('click', nextSlide);

    // Touch/swipe support
    let startX = 0, currentX = 0;
    track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; });
    track.addEventListener('touchmove', (e) => { currentX = e.touches[0].clientX; });
    track.addEventListener('touchend', () => {
      const diff = startX - currentX;
      if (Math.abs(diff) > 50) (diff > 0 ? nextSlide : prevSlide)();
    });

    // Click poster → play video
    track.addEventListener('click', (e) => {
      const poster = e.target.closest('.cskf_vid_poster');
      if (poster) {
        const video = poster.parentElement.parentElement.querySelector('video');
        const rect = poster.getBoundingClientRect();
        
        // Position video over poster
        Object.assign(video.style, {
          position: 'fixed',
          left: `${rect.left}px`,
          top: `${rect.top}px`,
          width: `${rect.width}px`,
          height: `${rect.height}px`,
          borderRadius: '12px',
          zIndex: '1000',
          display: 'block'
        });
        
        video.play();
        poster.parentElement.style.opacity = '0';
        poster.parentElement.style.pointerEvents = 'none';
        
        // Close on video end or click outside
        const closeVideo = () => {
          video.style.display = 'none';
          poster.parentElement.style.opacity = '1';
          poster.parentElement.style.pointerEvents = 'auto';
        };
        video.onended = closeVideo;
        video.addEventListener('click', closeVideo, { once: true });
      }
    });

    // Initialize
    function init() {
      updateSlidesToShow();
      createSlides();
      createDots();
      updateCarousel();
    }

    init();

    window.addEventListener('resize', () => {
      updateSlidesToShow();
      createDots();
      updateCarousel();
    });
  })();
</script>


 












