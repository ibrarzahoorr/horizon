{%- style -%}
  .blume-grid-wrapper-{{ section.id }} {
    padding: 100px 0;
    background: {{ section.settings.bg_color }};
  }
  .section-header {
    text-align: center;
    margin-bottom: 60px;
    position: relative;
  }
  .slider-arrows {
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    gap: 15px;
  }
  .slider-arrow {
    width: 44px;
    height: 44px;
    border: 1px solid var(--blume-blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: var(--blume-blue);
    color: #fff;
    transition: var(--transition-smooth);
    font-size: 20px;
  }
  .slider-arrow:hover {
    background: transparent;
    color: var(--blume-blue);
  }
  .blume-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 30px;
  }
  .modern-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 30px;
    color: var(--blume-blue);
  }
  .modern-title.hollow {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    -webkit-text-stroke: 1.5px var(--blume-blue);
    color: transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .blume-card-title {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: clamp(1.2rem, 2vw, 1.8rem);
    color: var(--blume-blue);
    line-height: 1.2;
    margin: 0;
    min-height: 2.4em; /* Keep titles aligned */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .blume-card-sub {
    font-size: 14px;
    color: var(--blume-blue);
    opacity: 0.8;
  }
  .price-row {
    margin-top: 10px;
    font-weight: 600;
    display: flex;
    gap: 10px;
    justify-content: center;
    color: var(--blume-blue);
  }
  .compare-price {
    text-decoration: line-through;
    opacity: 0.5;
    font-weight: 400;
  }
  @media (max-width: 991px) {
    .blume-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .slider-arrows { display: none; }
  }
  @media (max-width: 576px) {
    .blume-grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<section class="blume-grid-wrapper-{{ section.id }}">
  <div class="modern-container">
    <div class="section-header">
      <h2 class="modern-title {% if section.settings.hollow_title %}hollow{% endif %}">{{ section.settings.title }}</h2>
      {%- if section.settings.show_arrows -%}
        <div class="slider-arrows">
          <div class="slider-arrow">←</div>
          <div class="slider-arrow">→</div>
        </div>
      {%- endif -%}
    </div>

    <div class="blume-grid">
      {%- for block in section.blocks -%}
        <div class="blume-card" {{ block.shopify_attributes }}>
          <div class="blume-card-image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', style: 'width: 100%; height: 100%; object-fit: contain;' }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            
            {%- if block.settings.sale_tag != blank -%}
              <span class="blume-badge">
                {{ block.settings.sale_tag | split: ' ' | first }}<br>
                {{ block.settings.sale_tag | split: ' ' | last }}
              </span>
            {%- endif -%}
          </div>
          
          <div class="blume-card-content">
            <h3 class="blume-card-title">{{ block.settings.title }}</h3>
            <span class="blume-card-sub">{{ block.settings.subtitle }}</span>
            <div class="price-row">
              {%- if block.settings.compare_price != blank -%}
                <span class="compare-price">{{ block.settings.compare_price }}</span>
              {%- endif -%}
              <span class="current-price">{{ block.settings.price }}</span>
            </div>
            <a href="{{ block.settings.link }}" class="modern-btn" style="width: 100%; margin-top: 15px;">{{ block.settings.button_label | default: 'SHOP NOW' }}</a>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_btn_label != blank -%}
      <div style="text-align: center; margin-top: 50px;">
        <a href="{{ section.settings.footer_btn_link }}" class="modern-btn" style="background: transparent; color: var(--blume-blue); padding: 5px 0; border: none; border-bottom: 2px solid var(--blume-blue); border-radius: 0;">{{ section.settings.footer_btn_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blume Bundles Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "BEST BUNDLES"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "boolean",
      "id": "hollow_title",
      "label": "Use Hollow Title Style",
      "default": true
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns On Desktop",
      "default": 3
    },
    {
      "type": "boolean",
      "id": "show_arrows",
      "label": "Show Slider Arrows",
      "default": true
    },
    {
      "type": "text",
      "id": "footer_btn_label",
      "label": "Footer Link Text"
    },
    {
      "type": "url",
      "id": "footer_btn_link",
      "label": "Footer Link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "sale_tag",
          "label": "Sale Badge Text",
          "default": "53% OFF"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Bundle Title",
          "default": "Ultimate Clear Skin Edit"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Fight Breakouts. Fade Marks. Stay Clear."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Current Price",
          "default": "Rs.27,200.00"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare at Price",
          "default": "Rs.54,800.00"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Product Link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blume Bundles Grid",
      "blocks": [
        { "type": "product", "settings": { "title": "Ultimate Clear Skin Edit", "sale_tag": "53% OFF" } },
        { "type": "product", "settings": { "title": "Clear Skin Kit: Acne Essentials", "sale_tag": "36% OFF" } },
        { "type": "product", "settings": { "title": "The Fresh Face Edit", "sale_tag": "30% OFF" } }
      ]
    }
  ]
}
{% endschema %}
