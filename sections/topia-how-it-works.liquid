    <div class='topia__how-image mt1 pt05'>
      <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/how_trees.png?50606' alt='palm tree illustrations' />
      <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/how_trees.png?50606' alt='palm tree illustrations' />
