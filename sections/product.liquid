{% include 'bold-product' with product, hide_action: 'break' %}{% if bold_hidden_product %}{% break %}{%endif %}
{% include 'product-schema' %}
{% include 'product-hero' %}

<div class='js-show-add-cart' data-module='showAdd'></div>
{% include 'product-text-image' %}
{% include 'product-breakdown' %}
{% include 'product-steps' %}

{%- comment -%} Reviews module before product-inside {%- endcomment -%}

{% if product.handle == 'meltdown-acne-oil-1' %}
  <section class='bg-w pv1 pm60 pl100 o-h rel z4'>
    <div class='container--mm mha pt2 ph2 pb1 phm4'> 
      {% render 'junip-product-review', product: product %}
    </div>
  </section> 
{% endif %}

{% include 'product-inside' %}
{% include 'product-plays' %}
{% comment %}
  {% include 'product-testimonial' %} 
{% endcomment %}
{% include 'product-accordion' %}

{%- comment -%} Reviews module exclude for the specified product {%- endcomment -%}
{% unless product.handle == 'meltdown-acne-oil-1' %}
  <section class='bg-w pv1 pm60 pl100 o-h rel z4'>
    <div class='container--mm mha pt2 ph2 pb1 phm4'>
      {% render 'junip-product-review', product: product %}
    </div>
  </section>
{% endunless %}


<div class='bg-w rel z4 px05 ph15'>
  <div class='container--xl mha'>
    <div id='storytap-videos'></div>
  </div>
</div>

{% schema %}
  {
    "name": "Product pages",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_share_buttons",
        "label": "Show social sharing buttons",
        "default": true
      }
    ]
  }
{% endschema %}
