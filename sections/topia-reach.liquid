<section class='rel z3 pm100 pl100 ptl160' data-module='animateIn'>
  <div class='container--xl mxa px15'>
    <div class='ac mb1 pb1'>
      <h2 class='h2 hero-h2 mb05 topia__reach-header cooper'>{{section.settings.heading}}</h2>
      <div class='container--s mxa topia__reach-desc'>
        <p>{{section.settings.description}}</p>
        <a href='#smile-home' class='caps js-open-smile btn no-ajax btn__topia rel'>
          <span class='rel z2'>Take me to Blumetopia</span>
          <video class='abs x y top left' muted autoplay loop>
            <source src='{{ 'button_water.static.mp4' | asset_url }}' type='video/mp4'>
          </video>
        </a>
      </div>
    </div>
  </div>
  <div class='p15 topia__path' data-module='topiaBox'>
    <div class='topia__box-wrapper topia__box-left container--l mxa rel'>
      <div class='topia__box rel z3'>
        <div class='topia__box-header px1 f x aic jcb bgtb'>
          <div class='topia__box-lines rel pr1'></div>
          <h5 class='mono caps mx0 px0 pl1'>Path to Blumetopia</h5>
        </div>
        <div class='topia__box-content bg-w'>
          <div class='topia__box-table mono'>
            <div class='topia__box-table_single caps mono ac'>
              <h5 class='mx0 line-item px05 first'></h5>
              <h5 class='mx0 line-item px05'>Friends</h5>
              <h5 class='mx0 line-item px05'>BFF</h5>
              <h5 class='mx0 line-item px05'>Soulmates</h5>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Qualification</h5>
              <h5 class='mx0 line-item px05'>0-10K</h5>
              <h5 class='mx0 line-item px05'>10K-20K</h5>
              <h5 class='mx0 line-item px05'>20K+</h5>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Blume Bucks earned per $ spent</h5>
              <h5 class='mx0 line-item px05'>100</h5>
              <h5 class='mx0 line-item px05'>150</h5>
              <h5 class='mx0 line-item px05'>200</h5>
            </div>
            {% comment %}
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Access to our FB group</h5>
              <div class='mx0 line-item px05'>
                <img src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' /></div>
              <div class='mx0 line-item px05'>
                <img src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' /></div>
              <div class='mx0 line-item px05'>
                <img src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            {% endcomment %}
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Access to special promos</h5>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Limited Edition Merch</h5>
              <div class='mx0 line-item px05'></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Be one of our Close Friends on IG</h5>
              <div class='mx0 line-item px05'></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' /></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>

            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Get an invite to our private FB Group</h5>
              <div class='mx0 line-item px05'></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' /></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Insider access to new products</h5>
              <div class='mx0 line-item px05'></div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Birthday gift</h5>
              <div class='mx0 line-item px05'>
              </div>
              <div class='mx0 line-item px05'>
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
            <div class='topia__box-table_single mono ac'>
              <h5 class='mx0 line-item px05 first'>Free shipping always</h5>
              <div class='mx0 line-item px05'>
              </div>
              <div class='mx0 line-item px05'>
              </div>
              <div class='mx0 line-item px05'>
                <img class="lazyload" data-src='https://cdn.shopify.com/s/files/1/0003/4580/0755/files/star_points.png?50815' alt='star' />
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class='topia__box-two z2 abs x y top left bgty'></div>
      <div class='topia__box-three z1 abs x y top left bgtp'></div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Topia Reach",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Reaching Blumetopia"
      },
      {
        "type": "text",
        "id": "description",
        "label": "description",
        "default": "Reach Full Blume to receive exclusive perks, such as a birthday gift and access to special promotions! Becoming part of the Blume Club is easy and free. The more Blume Bucks you earn the more you Blume!"
      }
    ],
    "presets": [{
      "name": "Topia Reach",
      "category": "Topia"
    }]
  }
{% endschema %}
