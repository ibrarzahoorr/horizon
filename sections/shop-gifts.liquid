<style>
/* Product Card Grid Layout */
.product-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  padding: 2rem 0;
  max-width: 1400px;
  margin: 0 auto;
}

.product-card {
    background: transparent;
    overflow: hidden;
    position: relative;
}

/* Product Image */
.product-image-link {
  display: block;
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}

.product-image-link img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
 

.product-info {
    padding: 10px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left;
}

/* Product Title */
.product-title {
  font-size: 1em;
  font-weight: 600;
  line-height: 1.3;
  color: #1a1a1a;
  margin: 0;
  transition: color 0.2s ease;
}

.product-title a {
  color: inherit;
  text-decoration: none;
}

.product-title a:hover {
  color: #0066cc;
}

/* Product Pricing */
.product-pricing {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

/* Compare At Price (Sale Price) */
.compare-at-price {
  font-size: 0.875rem;
  color: #666;
  text-decoration: line-through;
  font-weight: 500;
}

/* Current Product Price */
.product-price {
  font-size: 1.25rem;
  font-weight: 700;
  color: #d63031;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

/* Hidden Variant ID */
.variant-id {
  font-size: 0.75rem;
  color: transparent;
}

/* View Product Button */
.product-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
  color: white;
  text-decoration: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.875rem;
  transition: all 0.2s ease;
  margin-top: auto;
  justify-content: center;
}

.product-link:hover {
  background: linear-gradient(135deg, #0052a3 0%, #003d7a 100%);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(0,102,204,0.3);
}

/* Responsive Design */
@media (max-width: 768px) {
  .product-cards-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    padding: 1.5rem 1rem;
  }
  
  .product-info {
    padding: 1.25rem;
  }
  
  .product-title {
    font-size: 1rem;
  }
  
  .product-price {
    font-size: 1.125rem;
  }
}

@media (max-width: 480px) {
  .product-cards-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}
.rtct_title {text-align:left;}
/* Sale Badge (Optional Enhancement) */
.product-card[data-on-sale="true"]::before {
  content: 'Sale';
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: #d63031;
  color: white;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  z-index: 10;
}
</style>

       
 {% endcomment %}
       
 

       
 

{% for block in section.blocks %}
  {% assign collectionBlock = block.settings %}
  <div class='bg-w rel'>
    <div class='fill-x container--xl mha px2 ac'>
      {% if collectionBlock.title != blank %}
      <h2 class='caps outline line-header'>
        <span class='rel z2 ph05 inline-block'>{{ collectionBlock.title | escape }}</span>
      </h2>
      {% endif %}

      {%- assign collection = collections[collectionBlock.collection] -%}
      <div class='collection__grid-clean'>
          {% for product in collection.products limit: 24 %}
            {% include 'collection-item-update' %}
          {% endfor %}
        <div class='collection__item mb15 rel'></div>
      </div>
    </div>
  </div>
{% endfor %}

{% schema %}
  {
    "name": "Shop Gifts",
    "max_blocks": 5,
    "blocks": [{
      "type": "list",
      "name": "Collection",
      "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Bundle"
      },
      {
        "id": "collection",
        "type": "collection",
        "label": "Collection"
      }
      ]
    }],
    "presets": [{
      "name": "Shop Gifts",
      "category": "Shop"
    }]
  }
{% endschema %}