{% assign product_handles1 = 'meltdown-gel-cleanser-made-with-salicylic-acid,meltdown-gel-cream-for-acne-prone-skin,sunburst-mineral-spf-50' %}
{%- if product_handles1 -%}
<div class="bg-w rel gg_wrap" id="product_ha1">
  <div class="fill-x container--xl mha px2 ac">
  <div class="rtct_title"> 
	  <h3 class="serif" style=" margin: 0; "> For the “Wash My Face With Hand Soap” Boyfriend</h3> 
	  <p style=" margin: 0 0 20px; font-size: 15px; "> He believes one product can do it all and that’s all he needs. Time to introduce him to a real routine (that won’t freak him out). </p> 
  </div>
    <div class="collection__grid-clean">
  {%- assign handles_array = product_handles1 | split: ',' -%}
  {%- for handle in handles_array -%}
    {%- assign trimmed_handle = handle | strip -%}
    {%- assign current_product = all_products[trimmed_handle] -%}
    <div class="collection__item-clean rel">
	  
	  
    {%- if current_product != blank -%}
      <div class="product-card" data-product-handle="{{ trimmed_handle }}">
        {%- if current_product.featured_image -%}
          <a href="{{ current_product.url }}" class="product-image-link">
            <img 
              src="{{ current_product.featured_image | img_url: '400x400' }}"
              alt="{{ current_product.featured_image.alt | escape }}"
              loading="lazy"
              width="400" 
              height="400"
            >
          </a>
        {%- endif -%}
        
        <div class="product-info">
          <h3 class="product-title serif">
            <a href="{{ current_product.url }}">{{ current_product.title }}</a>
          </h3>
           
            {% assign kicker = current_product.metafields.sf_extended_informat.kicker %} 
            {% if kicker %}
			<div class='collection__item-description'>
              <h5 style=" margin: 0; font-size: 14px; letter-spacing: 0; ">{{ kicker }}</h5>
			 </div>
            {% endif %} 
       
          <a href="{{ current_product.url }}" class="btn btn__outline bold fill-x">SHOP NOW - {{ current_product.first_available_variant.price | money }}</a>
        </div>
      </div>
	  </div>
    {%- endif -%}
  {%- endfor -%}
  
     </div>
  </div>
</div>
{%- endif -%}




