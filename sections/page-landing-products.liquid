<section class="page-landing__products bg-lp px1 pm100">
  <div class="landing-products__content ac">
    {% if section.settings.heading != blank %}
      <h2 class="serif mt0 mb0">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p>{{ section.settings.description }}</p>
    {% endif %}
  </div>
  {% if section.blocks.size > 0 %}
    <div class="landing-products__products f jcc container--l mxa">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        {% assign price = block.settings.price | prepend: '$' %}
        {% include 'collection-item' with 
          product: product, 
          offer: price,
          product_image: block.settings.image, 
          context: 'landing',
          prodTitle: block.settings.heading, 
          subscription_variant: product.variants[0].metafields.subscriptions.discount_variant_id,
          subscription_discount: product.metafields.accentuate.subscription_discount_code
        %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
  {
    "name": "Products",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description"
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product",
        "settings": [
          {
            "type": "header",
            "content": "Settings"
          },
          {
            "type": "product",
            "id": "product",
            "label": "Product"
          },
          {
            "type": "header",
            "content": "Content"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "price",
            "label": "Price ($)"
          }
        ]
      }
    ]
  }
{% endschema %}