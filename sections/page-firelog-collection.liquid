<div class="page-fire__collection" style="background-color: #fff;">
  <div class="container--xl px2 mxa">
    <h2 class="caps outline line-header ac">{{ section.settings.heading }}</h2>

    {%- assign collection = collections[section.settings.collection] -%}
    <div class='f jcb fw collection__grid'>
      {% for product in collection.products limit: 24 %}
        {% include 'collection-item' %}
      {% endfor %}
      <div class='collection__item mb15 rel'></div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Collection",
    "settings": [
      {
        "type": "header",
        "content": "Settings"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }
    ]
  }
{% endschema %}