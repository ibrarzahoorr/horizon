{%- style -%}
  .benefits-wrapper {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
    background-color: #faf5f0;
  }
  .benefits-container {
    display: flex;
    align-items: center;
    gap: 80px;
    position: relative;
    z-index: 1;
  }
  .benefits-images {
    flex: 0 0 50%;
    position: relative;
  }
  .benefits-images img {
    width: 100%;
    height: auto;
    display: block;
  }
  .benefits-content {
    flex: 0 0 45%;
    position: relative;
    z-index: 2;
  }
  .benefits-content h2 {
    font-family: var(--font-heading--family);
    font-size: 36px;
    font-weight: 600;
    margin-bottom: 20px;
    color: #1a3a5c;
    line-height: 1.2;
  }
  .benefits-description {
    font-size: 16px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 35px;
  }
  .benefit-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
    color: #1a3a5c;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .benefit-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .benefit-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  @media (max-width: 991px) {
    .benefits-container { flex-direction: column; gap: 40px; }
    .benefits-images, .benefits-content { flex: 1; width: 100%; }
    .benefits-content h2 { font-size: 28px; }
  }
{%- endstyle -%}

<section class="benefits-wrapper">
  <div class="modern-container">
    <div class="benefits-container">
      <div class="benefits-images">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="benefits-content">
        <h2>{{ section.settings.title }}</h2>
        {%- if section.settings.description != blank -%}
          <div class="benefits-description">{{ section.settings.description }}</div>
        {%- endif -%}
        <ul class="benefit-list">
          {%- for block in section.blocks -%}
            <li class="benefit-item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <span class="benefit-icon">
                  {{ block.settings.image | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.text }}
                </span>
              {%- endif -%}
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blume Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "We make going all natural second nature."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Made with nature's best ingredients — Blume's products are powerful but gentle and always easy to use. Our promise: high performance essentials that safe for sensitive skin, always."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Call Out",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Upload SVG or PNG icon (40x40px recommended)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Vegan"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blume Benefits",
      "blocks": [
        { "type": "callout", "settings": { "text": "Vegan" } },
        { "type": "callout", "settings": { "text": "Certified Clean" } },
        { "type": "callout", "settings": { "text": "Women Owned" } },
        { "type": "callout", "settings": { "text": "Climate Neutral" } },
        { "type": "callout", "settings": { "text": "Plastic Neutral" } }
      ]
    }
  ]
}
{% endschema %}
