<section class="page-landing__value-props px1 pm100" style="background-color: {{ section.settings.bg_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="section-heading serif mt0 ac">{{ section.settings.heading }}</h2>
  {% endif %}
  <div class="value-props f jcc ais">
    {% for block in section.blocks %}
      <div class="value-prop">
        <img class="header-image lazyload" data-src="{{ block.settings.image | img_url: '300x' }}" data-srcset="{{ block.settings.image | img_url: '600x' }} 2x">
        <div class="props-container" style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};">
          <h5 class="caps bold ac">{{ block.settings.heading }}</h5>
          {%- assign props = block.settings.props | split: '|' -%}
          <ul class="props">
            {% for prop in props %}
              <li class="f aic">
                <img src="{{ block.settings.bullet | img_url: '50x' }}">
                {{ prop | strip }}
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
  {
    "name": "Value Props",
    "settings": [
      {
        "type": "header",
        "content": "Settings"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color",
        "default": "#e6eff3"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }
    ],
    "blocks": [
      {
        "type": "column",
        "name": "Column",
        "settings": [
          {
            "type": "header",
            "content": "Settings"
          },
          {
            "type": "color",
            "id": "bg_color",
            "label": "Background Color"
          },
          {
            "type": "color",
            "id": "text_color",
            "label": "Text Color"
          },
          {
            "type": "header",
            "content": "Content"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "textarea",
            "id": "props",
            "label": "Props",
            "info": "Enter all of the value props for this column, separated by vertical bars (|)"
          },
          {
            "type": "image_picker",
            "id": "bullet",
            "label": "Bullet",
            "info": "Upload a png of the icon used for the bullet of each prop."
          }
        ]
      }
    ]
  }
{% endschema %}