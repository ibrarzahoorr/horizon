{%- style -%}
  .skin-type-wrapper {
    padding: 80px 0;
    background: #fdf5ef; /* Soft peach from image */
  }
  .skin-type-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  @media (max-width: 991px) {
    .skin-type-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 576px) {
    .skin-type-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{%- endstyle -%}

<section class="skin-type-wrapper">
  <div class="modern-container">
    <div class="section-header">
      <h2>{{ section.settings.title }}</h2>
      <div class="slider-arrows">
        <div class="slider-arrow">←</div>
        <div class="slider-arrow">→</div>
      </div>
    </div>

    <div class="skin-type-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="skin-type-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="skin-type-overlay">
            {{ block.settings.title }}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blume Skin Types",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SHOP BY SKIN TYPE"
    }
  ],
  "blocks": [
    {
      "type": "type",
      "name": "Skin Type",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pores"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blume Skin Types",
      "blocks": [
        { "type": "type", "settings": { "title": "Pores" } },
        { "type": "type", "settings": { "title": "Acne-Prone" } },
        { "type": "type", "settings": { "title": "Dark Spots" } },
        { "type": "type", "settings": { "title": "Sensitive" } },
        { "type": "type", "settings": { "title": "Dry Skin" } }
      ]
    }
  ]
}
{% endschema %}
