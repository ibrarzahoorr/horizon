{%- style -%}
  .skin-type-wrapper {
    padding: 60px 0;
    background: {{ section.settings.background_color }};
  }
  .skin-type-header {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 40px;
  }
  .skin-type-title {
    font-family: var(--font-heading--family);
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    margin: 0;
  }
  .skin-type-arrows {
    position: absolute;
    right: 0;
    display: flex;
    gap: 12px;
  }
  .skin-type-arrow {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: {{ section.settings.arrow_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }
  .skin-type-arrow:hover {
    opacity: 0.8;
  }
  .skin-type-arrow svg {
    width: 20px;
    height: 20px;
    fill: {{ section.settings.arrow_color }};
  }
  .skin-type-slider {
    overflow: hidden;
    position: relative;
  }
  .skin-type-track {
    display: flex;
    gap: 16px;
    transition: transform 0.4s ease;
  }
  .skin-type-item {
    flex: 0 0 calc(var(--item-width) - var(--gap-adjust));
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 3/4;
  }
  .skin-type-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .skin-type-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(transparent, rgba(0,0,0,0.4));
    color: #fff;
    font-family: var(--font-heading--family);
    font-size: 24px;
    font-weight: 600;
    text-align: center;
  }
  @media (max-width: 1200px) {
    .skin-type-item {
      flex: 0 0 calc(var(--item-width) - var(--gap-adjust));
    }
  }
  @media (max-width: 991px) {
    .skin-type-title {
      font-size: 32px;
    }
    .skin-type-arrows {
      position: static;
      margin-top: 20px;
      justify-content: center;
    }
    .skin-type-header {
      flex-direction: column;
      gap: 20px;
    }
  }
  @media (max-width: 768px) {
    .skin-type-item {
      flex: 0 0 calc(50% - 8px);
    }
    .skin-type-title {
      font-size: 28px;
    }
    .skin-type-arrows {
      display: flex;
      margin-top: 16px;
    }
    .skin-type-arrow {
      width: 40px;
      height: 40px;
    }
    .skin-type-arrow svg {
      width: 16px;
      height: 16px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns = section.settings.columns
  assign item_width = 100 | divided_by: columns
  assign gap_adjust = 16 | times: columns | minus: 16 | divided_by: columns
-%}

<section class="skin-type-wrapper" data-section-id="{{ section.id }}" style="--item-width: {{ item_width }}%; --gap-adjust: {{ gap_adjust }}px;">
  <div class="modern-container">
    <div class="skin-type-header">
      <h2 class="skin-type-title">{{ section.settings.title }}</h2>
      {%- if section.blocks.size > 2 -%}
        <div class="skin-type-arrows">
          <button class="skin-type-arrow skin-type-arrow-prev" aria-label="Previous">
            <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <button class="skin-type-arrow skin-type-arrow-next" aria-label="Next">
            <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div class="skin-type-slider">
      <div class="skin-type-track" id="skin-type-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link }}" class="skin-type-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            <div class="skin-type-overlay">
              {{ block.settings.title }}
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;
  
  const track = section.querySelector('.skin-type-track');
  const prevBtn = section.querySelector('.skin-type-arrow-prev');
  const nextBtn = section.querySelector('.skin-type-arrow-next');
  
  if (!track || !prevBtn || !nextBtn) return;
  
  let currentIndex = 0;
  const items = track.querySelectorAll('.skin-type-item');
  const totalItems = items.length;
  
  function getVisibleItems() {
    const columns = {{ section.settings.columns }};
    if (window.innerWidth >= 1200) return columns;
    if (window.innerWidth >= 992) return Math.min(columns, 4);
    if (window.innerWidth >= 768) return Math.min(columns, 3);
    return 2;
  }
  
  function updateSlider() {
    const visibleItems = getVisibleItems();
    const maxIndex = Math.max(0, totalItems - visibleItems);
    currentIndex = Math.min(currentIndex, maxIndex);
    
    const itemWidth = items[0]?.offsetWidth || 0;
    const gap = 16;
    const offset = currentIndex * (itemWidth + gap);
    track.style.transform = `translateX(-${offset}px)`;
    
    prevBtn.style.opacity = currentIndex === 0 ? '0.5' : '1';
    nextBtn.style.opacity = currentIndex >= maxIndex ? '0.5' : '1';
  }
  
  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateSlider();
    }
  });
  
  nextBtn.addEventListener('click', () => {
    const visibleItems = getVisibleItems();
    const maxIndex = Math.max(0, totalItems - visibleItems);
    if (currentIndex < maxIndex) {
      currentIndex++;
      updateSlider();
    }
  });
  
  window.addEventListener('resize', updateSlider);
  updateSlider();
})();
</script>

{% schema %}
{
  "name": "Blume Skin Types",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SHOP BY SKIN TYPE"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Cards per row",
      "min": 2,
      "max": 6,
      "step": 0.5,
      "default": 5
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f0eb"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow Background",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Icon Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "type",
      "name": "Skin Type",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pores"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blume Skin Types",
      "blocks": [
        { "type": "type", "settings": { "title": "Pores" } },
        { "type": "type", "settings": { "title": "Acne-Prone" } },
        { "type": "type", "settings": { "title": "Dark Spots" } },
        { "type": "type", "settings": { "title": "Sensitive" } },
        { "type": "type", "settings": { "title": "Dry Skin" } }
      ]
    }
  ]
}
{% endschema %}
