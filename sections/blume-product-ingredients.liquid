{%- style -%}
  .product-ingredients-section {
    padding: 48px 0;
    background: {{ section.settings.background_color }};
  }
  .product-ingredients-title {
    font-family: var(--font-heading--family);
    font-size: 28px;
    font-weight: 600;
    color: {{ section.settings.title_color }};
    text-align: center;
    margin-bottom: 40px;
  }
  .key-ingredients {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .key-ingredient {
    text-align: center;
    padding: 32px 20px;
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e8e8e8;
  }
  .key-ingredient-name {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: {{ section.settings.accent_color }};
    margin-bottom: 12px;
  }
  .key-ingredient-desc {
    font-size: 14px;
    color: #555;
    line-height: 1.5;
  }
  .full-ingredients {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .full-ingredients-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #999;
    margin-bottom: 12px;
  }
  .full-ingredients-text {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
    font-style: italic;
  }
  @media (max-width: 991px) {
    .key-ingredients {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 576px) {
    .key-ingredients {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

{%- liquid
  assign key_ingredients_json = product.metafields.custom.key_ingredients
  assign full_ingredients = product.metafields.custom.full_ingredients
-%}

{%- if key_ingredients_json != blank or full_ingredients != blank -%}
  <div class="product-ingredients-section" data-section-id="{{ section.id }}">
    <div class="modern-container">
      <h2 class="product-ingredients-title">{{ section.settings.title }}</h2>
      
      {%- if key_ingredients_json != blank -%}
        <div class="key-ingredients">
          {%- assign ingredients = key_ingredients_json | parse_json -%}
          {%- for ingredient in ingredients -%}
            <div class="key-ingredient">
              <div class="key-ingredient-name">{{ ingredient.name }}</div>
              <p class="key-ingredient-desc">{{ ingredient.benefit }}</p>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      
      {%- if full_ingredients != blank -%}
        <div class="full-ingredients">
          <div class="full-ingredients-label">Full Ingredients</div>
          <p class="full-ingredients-text">{{ full_ingredients }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Blume Product Ingredients",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Key Ingredients"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Ingredient Name Color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#faf5f0"
    }
  ],
  "presets": [
    {
      "name": "Blume Product Ingredients"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
