      "id": "title_color",
      "label": "Title Color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "active_background",
      "label": "Active Card Background",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "badge_background",
