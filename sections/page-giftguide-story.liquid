<div class="page-giftguide__story bg-lb rel has_divider">
  <div class="gg-story__divider abs top left right">
    <svg width="1802" height="340" viewBox="0 0 1802 340" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M619.599 98.0879C298.703 102.964 39.4106 228.096 0.232422 283.353L0.233274 339.5L1801.34 339.5V0.0717134C1712.35 20.2059 1688.88 45.856 1501.96 85.9691C1268.3 136.11 1020.72 91.9927 619.599 98.0879Z" fill="#E9EFF4"/>
    </svg>
  </div>
  {% include 'page-giftguide-story' with 
    heading: section.settings.heading,
    description: section.settings.description,
    image: section.settings.image,
    button_cta: section.settings.button_cta,
    button_link: section.settings.button_link
  %}
</div>

{% schema %}
  {
    "name": "Story",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Our Story"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Building a female-forward future. For people who believe in the power of their choices."
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "text",
        "id": "button_cta",
        "label": "Button CTA",
        "default": "Learn More"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ]
  }
{% endschema %}