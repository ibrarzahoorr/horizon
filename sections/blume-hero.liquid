{%- style -%}
  .blume-hero-wrapper {
    background-color: var(--blume-light-blue);
    padding: 0;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    min-height: 80vh;
  }
  .blume-hero-content-side {
    flex: 0 0 45%;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 60px 80px;
    background-color: var(--blume-light-blue);
  }
  .blume-hero-media-side {
    flex: 0 0 55%;
    position: relative;
    background-color: var(--blume-light-blue);
  }
  .blume-hero-media-side img.main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .signature-overlay {
    position: absolute;
    top: 50px;
    left: 10%;
    width: 250px;
    z-index: 5;
    transform: rotate(-10deg);
    pointer-events: none;
  }
  .hero-text-container {
    max-width: 500px;
  }
  .hero-text-container h1 {
    font-size: clamp(2.8rem, 4.5vw, 4.2rem);
    line-height: 1;
    margin-bottom: 30px;
    color: var(--blume-blue);
  }
  .hero-text-container .subtitle {
    font-size: 1.1rem;
    line-height: 1.5;
    margin-bottom: 35px;
    color: var(--blume-blue);
    opacity: 0.9;
  }
  .hero-text-container {
    display: flex;
    flex-direction: column;
  }
  .hero-text-container .hero-heading { order: 1; }
  .hero-text-container .subtitle { order: 2; }
  .hero-text-container .btn-offset-wrapper { order: 3; }
  .hero-text-container .stars-row { order: 4; }
  .stars-row {
    margin-top: 25px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--blume-blue);
    font-weight: 600;
  }
  .stars-row .stars {
    color: #ffb800;
    font-size: 18px;
  }
  @media (max-width: 1200px) {
    .blume-hero-content-side { padding: 60px 40px; }
  }
  @media (max-width: 991px) {
    .blume-hero-wrapper { flex-direction: column; }
    .blume-hero-content-side, .blume-hero-media-side { flex: auto; width: 100%; }
    .blume-hero-content-side { 
      justify-content: center; 
      text-align: center; 
      order: 2; 
      padding: 40px 20px;
      display: flex;
      flex-direction: column;
    }
    .blume-hero-media-side { order: 1; min-height: auto; }
    .blume-hero-media-side img.main-img {
      height: auto;
      aspect-ratio: 1/1;
      object-fit: cover;
      object-position: center top;
    }
    .signature-overlay { width: 150px; left: 50%; transform: translateX(-50%) rotate(-10deg); top: 20px; }
    .btn-offset-wrapper { margin: 0 auto 20px; }
    .stars-row { justify-content: center; margin-bottom: 25px; margin-top: 0; }
    .hero-text-container h1 { margin-bottom: 20px; }
    .hero-text-container .subtitle { margin-bottom: 0; }
    /* Mobile order: Button -> Reviews -> Title -> Description */
    .hero-text-container .btn-offset-wrapper { order: 1; }
    .hero-text-container .stars-row { order: 2; }
    .hero-text-container .hero-heading { order: 3; }
    .hero-text-container .subtitle { order: 4; }
  }
{%- endstyle -%}

<section class="blume-hero-wrapper">
  <div class="blume-hero-content-side">
    <div class="hero-text-container animate-fade-up">
      <div class="btn-offset-wrapper">
        <div class="btn-offset-bg"></div>
        <a href="{{ section.settings.link }}" class="modern-btn offset">{{ section.settings.button_label }}</a>
      </div>

      <div class="stars-row">
        <span>{{ section.settings.reviews_text }}</span>
        <span class="stars">★★★★★</span>
      </div>

      <h1 class="hero-heading">{{ section.settings.title }}</h1>
      <div class="subtitle">{{ section.settings.text }}</div>
    </div>
  </div>
  
  <div class="blume-hero-media-side">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'main-img', loading: 'eager' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg main-img' }}
    {%- endif -%}
    
    {%- if section.settings.signature != blank -%}
      {{ section.settings.signature | image_url: width: 500 | image_tag: class: 'signature-overlay', alt: 'Signature' }}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blume Hero Refined",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Hydrate, Calm, and Glow with Pearl Drip Milky Toner"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pearl Drip calms redness, replenishes moisture, and leaves sensitive, acne-prone skin soft, balanced, and glowing.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews Subtext",
      "default": "5000+ 5 star reviews"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image (Model + Product)"
    },
    {
      "type": "image_picker",
      "id": "signature",
      "label": "Handwriting Signature Overlay"
    }
  ],
  "presets": [
    {
      "name": "Blume Hero Refined"
    }
  ]
}
{% endschema %}
