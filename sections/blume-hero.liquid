{%- style -%}
  .blume-hero-wrapper {
    background-color: var(--blume-soft-blue);
    padding: 60px 0;
    overflow: hidden;
  }
  .blume-hero-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .blume-hero-text {
    flex: 1;
    max-width: 500px;
  }
  .blume-hero-image {
    flex: 1.2;
    position: relative;
  }
  .blume-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .signature-overlay {
    position: absolute;
    top: -20px;
    right: 20px;
    width: 150px;
    z-index: 2;
  }
  .blume-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 25px;
    color: var(--blume-blue);
    font-weight: 500;
  }
  .blume-hero .subtitle {
    font-size: 1.1rem;
    margin-bottom: 30px;
    color: var(--blume-blue);
    opacity: 0.8;
  }
  .stars-row {
    margin-top: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--blume-blue);
  }
  @media (max-width: 991px) {
    .blume-hero-container {
      flex-direction: column;
      text-align: center;
      padding: 0 20px;
    }
    .blume-hero-text {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<section class="blume-hero-wrapper">
  <div class="blume-hero-container">
    <div class="blume-hero-text animate-fade-up">
      <h1>{{ section.settings.title }}</h1>
      <div class="subtitle">{{ section.settings.text }}</div>
      <a href="{{ section.settings.link }}" class="modern-btn">{{ section.settings.button_label }}</a>
      <div class="stars-row">
        <span>★★★★★</span>
        <span>Over 5,000+ 5-star reviews</span>
      </div>
    </div>
    <div class="blume-hero-image">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      {%- if section.settings.signature != blank -%}
        <img src="{{ section.settings.signature | image_url: width: 300 }}" class="signature-overlay" alt="Signature">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blume Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Hydrate, Calm, and Glow with Pearl Drip Milky Toner"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Gently remove surface impurities and excess oil for a clean and hydrated glow.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "signature",
      "label": "Signature Overlay"
    }
  ],
  "presets": [
    {
      "name": "Blume Hero"
    }
  ]
}
{% endschema %}
