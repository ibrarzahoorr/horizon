{%- style -%}
  .dermo-wrapper {
    padding: 80px 0;
    background: #f8f9fa;
  }
  .dermo-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dermo-split {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 80px;
  }
  .dermo-content {
    flex: 0 0 45%;
    text-align: left;
  }
  .dermo-content h3 {
    font-family: var(--font-heading--family);
    font-size: 40px;
    font-weight: 600;
    margin-bottom: 25px;
    color: #1a3a5c;
    line-height: 1.2;
  }
  .dermo-quote {
    font-size: 17px;
    line-height: 1.7;
    color: #1a3a5c;
    margin-bottom: 30px;
  }
  .dermo-doctor-name {
    font-size: 14px;
    font-weight: 700;
    color: #1a3a5c;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 5px;
  }
  .dermo-doctor-role {
    font-size: 14px;
    color: #555;
  }
  .dermo-image {
    flex: 0 0 50%;
    display: flex;
    justify-content: flex-end;
  }
  .dermo-image img {
    width: 100%;
    max-width: 450px;
    height: auto;
    display: block;
    object-fit: cover;
  }
  @media (max-width: 991px) {
    .dermo-split {
      flex-direction: column;
      gap: 40px;
    }
    .dermo-content {
      flex: 1;
      text-align: center;
    }
    .dermo-image {
      flex: 1;
      justify-content: center;
    }
    .dermo-image img {
      max-width: 100%;
    }
    .dermo-content h3 {
      font-size: 32px;
    }
  }
{%- endstyle -%}

<section class="dermo-wrapper">
  <div class="dermo-container">
    <div class="dermo-split">
      <div class="dermo-content">
        <h3>{{ section.settings.title }}</h3>
        <div class="dermo-quote">
          {{ section.settings.text }}
        </div>
        <div class="dermo-doctor-name">{{ section.settings.doctor_name }}</div>
        <div class="dermo-doctor-role">{{ section.settings.doctor_role }}</div>
      </div>
      <div class="dermo-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dermatologist Recommended",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Dermatologist Recommended"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Paragraph/Quote",
      "default": "Blume products focus on hydration to protect the skin barrier, yet also deliver gentle active ingredients to benefit the skin. Blume's emphasis on moisturizing ingredients and gentle actives means you get the most out of each product."
    },
    {
      "type": "text",
      "id": "doctor_name",
      "label": "Doctor Name",
      "default": "DR. LEELA ATHALYE"
    },
    {
      "type": "text",
      "id": "doctor_role",
      "label": "Doctor Role/Title",
      "default": "Board Certified Dermatologist"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Doctor Image"
    }
  ],
  "presets": [
    {
      "name": "Dermatologist Recommended"
    }
  ]
}
{% endschema %}
