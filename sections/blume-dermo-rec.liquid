{%- style -%}
  .dermo-wrapper {
    padding: 100px 0;
    background: #fff;
  }
  .dermo-content h3 {
    font-size: 32px;
    margin-bottom: 25px;
    color: var(--blume-blue);
    line-height: 1.2;
  }
  .dermo-content p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-light);
    margin-bottom: 30px;
  }
  .dermo-image img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }
{%- endstyle -%}

<section class="dermo-wrapper">
  <div class="modern-container">
    <div class="dermo-split">
      <div class="dermo-content animate-fade-up">
        <h3>{{ section.settings.title }}</h3>
        <div class="dermo-text">
          {{ section.settings.text }}
        </div>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link }}" class="modern-btn" style="background: transparent; color: var(--blume-blue); padding: 5px 0; border: none; border-bottom: 2px solid var(--blume-blue); border-radius: 0;">{{ section.settings.link_label }}</a>
        {%- endif -%}
      </div>
      <div class="dermo-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blume Dermo Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Dermatologist Recommended"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Gently remove surface impurities and excess oil for a clean and hydrated glow. Our products are formulated with dermatologists to ensure safety and efficacy.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link Label",
      "default": "LEARN MORE"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Doctor Image"
    }
  ],
  "presets": [
    {
      "name": "Blume Dermo Section"
    }
  ]
}
{% endschema %}
