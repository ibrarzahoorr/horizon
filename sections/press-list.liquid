{%- liquid
  assign set_background_color = section.settings.set_background_color
-%}
<style>
  .press__single_wrap {
    width: 100%;
  }
  .press__single_wrap {
    gap: 40px;
  }

  .press__slide-item {
    width: 100%;
    height: 100%;
    min-height: 40px !important;
    min-width: 120px !important;
    position: relative;
    overflow: hidden;
  }

  .no-quote-press,
  .no-quote-press .press__container,
  .no-quote-press .container--xl,
  .no-quote-press .press__slide-item img {
    padding: 0 !important;
  }
  @media (max-width: 820px) {
    [data-template-suffix="blume-babies"] .no-quote-press .flickity-enabled {
      padding-top: 10px;
      padding-bottom: 10px;
      min-height: 80px;
    }

    [data-template-suffix="blume-babies"] .marquee .flickity-slider {
      display: flex;
      align-items: center;
    }

    .no-quote-press .flickity-enabled {
      padding-top: 10px;
      padding-bottom: 20px;
    }
  }
  @media (min-width: 821px) {
    .no-quote-press .container--xl {
      max-width: 100% !important;
      margin: 0 !important;
    }

    [data-template-suffix="blume-babies"] .marquee {
      max-height: 60px;
    }

    .marquee {
      overflow: hidden;
      position: relative;
      display: flex;
      user-select: none;
      width: 100%;
      height: 100%;
      padding: 0;
      margin: 0;
      gap: 0;
    }

    .marquee-content {
      display: flex;
      flex-shrink: 0;
      animation: scroll {{ section.settings.scroll_duration }}s linear infinite;
      opacity: 1;
      animation-fill-mode: forwards;
    }

    .marquee-content::before {
      content: attr(data-content);
      margin-right: 1rem;
    }

    @keyframes scroll {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-100%);
      }
    }

    .scroll {
      animation: scroll 20s linear infinite;
    }

    .reverse {
      animation-direction: reverse;
    }
  }
</style>
{%- if set_background_color != false -%}
  {% style %}
    .bg-custom {
      background-color: {{ section.settings.background_color }};
    }
  {% endstyle %}
{%- endif -%}
{% if section.settings.quote_visible == true %}
  <section
    class='press bg-w rel z5'
    data-module='pressSlides'
    {% if set_background_color == true %}
    style="background-color: {{ section.settings.background_color }} !important;"
    {% endif %}>
    <div class='container--xl mha px1'>
      <div class='press__container ac'>
        {% if section.settings.quote_visible == true %}
          <div class='x ac'>
            <h5 class='caps bold mt1 pt1 s1'>{{ section.settings.title }}</h5>
          </div>
        {% endif %}
        <div class='f jcc aic x fw js-press-slides press__single_wrap  {% if section.settings.quote_visible == true %} press__main-slideshow  {% endif %} mxa' data-carousel-speed="{{ section.settings.sm_scroll_duration | times: 1000 }}">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              <div class='press__slide x ac js-single-slide'>
                <div class='press__slide-item f ac jcc aic'>
                  <img class='fill-x lazyload' data-src="{{ block.settings.press_item | img_url: '200x' }}" />
                </div>
                {% if section.settings.quote_visible == true %}
                  <div class='press__slide-text'>
                    <h3 class='serif bold'>"{{ block.settings.quote }}"</h3>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          {% endif %}
        </div>
        <div class='press__slide-d-text press__single_wrap mxa'>
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% if section.settings.quote_visible == true %}
                <div class='press__slide-text-d js-text-slides'>
                  <h3 class='serif bold'>"{{ block.settings.quote }}"</h3>
                </div>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
        {% if section.settings.quote_visible == true %}
          <div class='mv1 pv1'>
            <a href='/pages/press' class='btn btn__blue bold'>See All Press</a>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% else %}
  <section
    class='no-quote-press press bg-w rel z5'
    data-module='pressSlides'
    {% if set_background_color == true %}
    style="background-color: {{ section.settings.background_color }} !important;"
    {% endif %}>
    <div class='container--xl mha px1'>
      <div class='press__container ac'>
        {% if section.settings.quote_visible == true %}
          <div class='x ac'>
            <h5 class='caps bold mt1 pt1 s1'>{{ section.settings.title }}</h5>
          </div>
        {% endif %}
        <div class='marquee f jcc aic x js-press-slides press__single_wrap {% if section.settings.quote_visible == true %} press__main-slideshow  {% endif %} mxa' data-carousel-speed="{{ section.settings.sm_scroll_duration | times: 1000 }}">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              <div class='press__slide x ac js-single-slide marquee-content'>
                <div class='press__slide-item f ac jcc aic'>
                  <img class='fill-x lazyload' data-src="{{ block.settings.press_item | img_url: '200x' }}" />
                </div>
                {% if section.settings.quote_visible == true %}
                  <div class='press__slide-text'>
                    <h3 class='serif bold'>"{{ block.settings.quote }}"</h3>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          {% endif %}
        </div>


        <div class='press__slide-d-text press__single_wrap mxa'>
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% if section.settings.quote_visible == true %}
                <div class='press__slide-text-d js-text-slides'>
                  <h3 class='serif bold'>"{{ block.settings.quote }}"</h3>
                </div>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
        {% if section.settings.quote_visible == true %}
          <div class='mv1 pv1'>
            <a href='/pages/press' class='btn btn__blue bold'>See All Press</a>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}


{% schema %}
  {
    "name": "Press Items",
    "max_blocks": 12,
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "In the Press"
      },
      {
        "type": "checkbox",
        "id": "quote_visible",
        "label": "Show Quote",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "set_background_color",
        "label": "Set background color",
        "default": false
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#fff"
      }, {
        "type": "range",
        "id": "scroll_duration",
        "label": "Desktop Marquee Duration",
        "step": 1,
        "min": 1,
        "max": 30,
        "unit": "s",
        "default": 10,
        "info": "Set the marquee animation duration on desktop. By default, the marquee animations takes 10 seconds"
      }, {
        "type": "range",
        "id": "sm_scroll_duration",
        "label": "Mobile Marquee Duration",
        "step": 0.2,
        "min": 1,
        "max": 10,
        "unit": "s",
        "default": 3,
        "info": "Set the scroll animation duration on mobile. By default, the scroll animations takes 3 seconds"
      }
    ],
    "blocks": [
      {
        "type": "image",
        "name": "Image",
        "settings": [
          {
            "type": "image_picker",
            "id": "press_item",
            "label": "Image"
          }, {
            "type": "text",
            "id": "quote",
            "label": "Quote"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Press Items",
        "category": "sections"
      }
    ]
  }
{% endschema %}