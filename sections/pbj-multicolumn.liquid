{% liquid
    assign column_width = 100 | divided_by: section.blocks.size
    if section.blocks.size > 3
        assign column_width = 33
    endif
%}

{% style %}
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .bg-{{ section.id  }} {
        background-color: {{ section.settings.background_color }};
    }

    /* .columns-container-{{ section.id }} .column {
        width: {{ column_width }}%;
    } */

    @media only screen and (max-width: 767px) {
        .section-{{ section.id }}-padding {
            paddding-top: {{ section.settings.padding_top |  times: 0.75 }}px;
            paddding-bottom: {{ section.settings.padding_bottom |  times: 0.75 }}px;
        }

        /* .columns-container-{{ section.id }} .column {
            width: 100%;
        } */
    }
{% endstyle %}

<section class="section-{{ section.id }}-padding bg-{{ section.id  }}">
    {% if section.settings.title != blank %}
        <h2 class="h2 serif" style="text-align: center; padding: 0 10px;">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="columns-container columns-container-{{ section.id }}">
        {% for block in section.blocks %}
            <div class="column" {{ block.shopify_attributes }}>
                <div class="icon-and-text">
                    {% if block.settings.image != blank %}
                        <img class="column-img" src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.heading }}">
                    {% endif %}
    
                    {% if block.settings.heading != blank %}
                        <h4 class="h4 column-heading">{{ block.settings.heading }}</h4>
                    {% endif %}
    
                    {% if block.settings.text != blank %}
                        <div class="text-container">
                            {{ block.settings.text }}
                        </div>
                    {% endif %}
                </div>

                {% if block.settings.button_text != blank %}
                    <div class="column-button">
                        {% if block.settings.email_text != blank %}
                            {% assign email_msg = block.settings.email_text | replace: ' ', '%20' %}
                            <a href="mailto:friend@example.com?subject=Your%20Subject&body={{ email_msg }}" class="btn btn__blue bold"> {{ block.settings.button_text }}</a>
                        {% else %}
                            <a href="{{ block.settings.button_link | default: '#' }}" class="btn btn__blue bold">{{ block.settings.button_text }}</a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</section>

{% schema %}
{
    "name": "PBJ Multicolumn",
    "class": "pbj-multicolumn",
    "settings": [
        {
            "type": "inline_richtext",
            "id": "title",
            "label": "Title",
            "default": "PBJ Multicolumn"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Color",
            "default": "#ffffff"
        },
        {
            "type": "header",
            "content": "Padding"
        },
        {
            "type": "range",
            "id": "padding_top",
            "label": "Padding Top",
            "default": 20,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "label": "Padding Bottom",
            "default": 20,
            "min": 0,
            "max": 100,
            "step": 5
        }
    ],
    "blocks": [
        {
            "type": "column",
            "name": "Column",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Column Heading"
                },
                {
                    "type": "inline_richtext",
                    "id": "text",
                    "label": "Text",
                    "default": "Lorem ipsum dolor sit amet consectetur adipisicing elit. Ipsum ipsam consectetur animi minus in. Aliquid earum voluptatibus ratione optio. Dolores culpa dicta, commodi nesciunt obcaecati dolorum consequuntur? Hic, molestiae ex. ipsum dolor sit amet consectetur"
                },
                {
                    "type": "text",
                    "id": "button_text",
                    "label": "Button Text",
                    "default": "Button Text"
                },
                {
                    "type": "url",
                    "id": "button_link",
                    "label": "Button Link"
                },
                {
                    "type": "text",
                    "id": "email_text",
                    "label": "Email Text",
                    "info": "If filled, button will transform into an email sender with the predetermined provided text"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "PBJ Multicolumn",
            "settings": {},
            "blocks": [
                {
                    "type": "column"
                },
                {
                    "type": "column"
                },
                {
                    "type": "column"
                }
            ]
        }
    ]
}
{% endschema %}