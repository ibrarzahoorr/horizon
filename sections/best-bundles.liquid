{{ 'best-bundles.css' | asset_url | stylesheet_tag }}

{%- assign layout = section.settings.layout_style -%}
{%- assign block_count = section.blocks.size -%}
{%- assign zoom_enabled = section.settings.enable_center_zoom -%}
{%- assign zoom_scale   = section.settings.center_zoom_scale | divided_by: 100.0 -%}
{%- assign zoom_hover   = section.settings.center_zoom_hover | divided_by: 100.0 -%}
{%- assign zoom_lift    = section.settings.center_lift_px -%}

<style>
  #best-bundles-{{ section.id }} {
    --bb-zoom:       {{ zoom_scale }};
    --bb-zoom-hover: {{ zoom_hover }};
    --bb-lift:       {{ zoom_lift }}px;
    --bb-zoom-on:    {% if zoom_enabled %}1{% else %}0{% endif %};
  }
</style>

<section
  class="best-bundles-section"
  id="best-bundles-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-layout="{{ layout }}"
  data-auto-slide="{{ section.settings.auto_slide }}"
  data-slide-interval="{{ section.settings.slide_interval | times: 1000 }}"
>
  <div class="best-bundles-container">

    <h2 class="best-bundles-heading">
      {{ section.settings.heading | default: 'BEST BUNDLES' }}
    </h2>

    {%- if layout == 'grid' -%}
      {%- comment %} ── GRID LAYOUT ── {% endcomment %}
      <div class="best-bundles-grid best-bundles-grid--{{ block_count }}">
        {% for block in section.blocks %}
          {%- assign product = all_products[block.settings.product] -%}
          {% render 'bundle-card', block: block, product: product, index: forloop.index, total: block_count %}
        {% endfor %}
      </div>

    {%- else -%}
      {%- comment %} ── SLIDER LAYOUT ── {% endcomment %}
      <div class="best-bundles-slider-wrapper">
        <div class="best-bundles-track-outer">
          <div class="best-bundles-track" id="bb-track-{{ section.id }}">
            {% for block in section.blocks %}
              {%- assign product = all_products[block.settings.product] -%}
              <div class="bb-slide">
                {% render 'bundle-card', block: block, product: product, index: forloop.index, total: block_count %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {%- if section.settings.show_dots -%}
        <div class="bb-dots" id="bb-dots-{{ section.id }}">
          {% for block in section.blocks %}
            <button
              class="bb-dot{% if forloop.first %} is-active{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              data-index="{{ forloop.index0 }}"
            ></button>
          {% endfor %}
        </div>
      {%- endif -%}

    {%- endif -%}

  </div>
</section>

<script>
(function() {
  const sectionEl = document.getElementById('best-bundles-{{ section.id }}');
  if (!sectionEl) return;

  const layout       = sectionEl.dataset.layout;
  const autoSlide    = sectionEl.dataset.autoSlide === 'true';
  const interval     = parseInt(sectionEl.dataset.slideInterval, 10) || 4000;

  if (layout !== 'slider') return;

  const track    = document.getElementById('bb-track-{{ section.id }}');
  const slides   = track ? Array.from(track.querySelectorAll('.bb-slide')) : [];
  const dotsWrap = document.getElementById('bb-dots-{{ section.id }}');
  const dots     = dotsWrap ? dotsWrap.querySelectorAll('.bb-dot') : [];

  if (!track || slides.length === 0) return;

  let current    = 0;
  let slideTimer = null;

  function getVisible() {
    if (window.innerWidth < 600) return 1;
    if (window.innerWidth < 960) return 2;
    return 3;
  }

  function updateCenterZoom() {
    const vis = getVisible();
    slides.forEach((s, i) => {
      const card = s.querySelector('.bundle-card');
      if (!card) return;
      // Center index among visible slides
      const centerIndex = current + Math.floor(vis / 2);
      if (vis === 3 && i === centerIndex) {
        card.classList.add('bundle-card--featured');
      } else {
        card.classList.remove('bundle-card--featured');
      }
    });
  }

  function goTo(index) {
    const vis      = getVisible();
    const maxIndex = Math.max(0, slides.length - vis);
    current = Math.max(0, Math.min(index, maxIndex));

    const slideWidth = slides[0].offsetWidth;
    const gap = 24;
    track.style.transform = 'translateX(-' + (current * (slideWidth + gap)) + 'px)';

    dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    updateCenterZoom();
  }

  function next() {
    const vis      = getVisible();
    const maxIndex = Math.max(0, slides.length - vis);
    goTo(current >= maxIndex ? 0 : current + 1);
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { resetTimer(); goTo(parseInt(dot.dataset.index, 10)); });
  });

  // Touch / Swipe support
  let startX = 0;
  track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    const diff = startX - e.changedTouches[0].clientX;
    const vis = getVisible();
    const maxIndex = Math.max(0, slides.length - vis);
    if (Math.abs(diff) > 40) {
      resetTimer();
      diff > 0 ? next() : goTo(current <= 0 ? maxIndex : current - 1);
    }
  }, { passive: true });

  function startTimer() {
    if (!autoSlide) return;
    slideTimer = setInterval(next, interval);
  }

  function resetTimer() {
    clearInterval(slideTimer);
    startTimer();
  }

  // Init
  updateCenterZoom();
  startTimer();

  window.addEventListener('resize', function() { goTo(current); });
})();
</script>

{% schema %}
{
  "name": "Best Bundles",
  "tag": "section",
  "class": "section-best-bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "BEST BUNDLES"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout Style",
      "options": [
        { "value": "grid",   "label": "Grid (static, best for 3 items)" },
        { "value": "slider", "label": "Slider / Carousel" }
      ],
      "default": "slider"
    },
    {
      "type": "header",
      "content": "Slider Options"
    },
    {
      "type": "checkbox",
      "id": "auto_slide",
      "label": "Enable Auto-Slide",
      "default": true
    },
    {
      "type": "range",
      "id": "slide_interval",
      "label": "Auto-Slide Interval (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dot Indicators",
      "default": true
    },
    {
      "type": "header",
      "content": "Center Image Zoom"
    },
    {
      "type": "checkbox",
      "id": "enable_center_zoom",
      "label": "Enable Center Card Zoom",
      "default": true
    },
    {
      "type": "range",
      "id": "center_zoom_scale",
      "label": "Zoom Level (default state)",
      "info": "100 = no zoom, 103 = subtle zoom",
      "min": 100,
      "max": 150,
      "step": 1,
      "default": 103,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "center_zoom_hover",
      "label": "Zoom Level on Hover",
      "info": "Should be higher than default zoom",
      "min": 100,
      "max": 160,
      "step": 1,
      "default": 106,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "center_lift_px",
      "label": "Center Card Lift (px)",
      "info": "How many px the center card rises above others",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (overrides product image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (overrides product title)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle / Short Description"
        },
        {
          "type": "text",
          "id": "discount_percent",
          "label": "Discount % (e.g. 53)",
          "placeholder": "53"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Original Price (e.g. Rs.54,400.00)"
        },
        {
          "type": "text",
          "id": "sale_price",
          "label": "Sale Price (e.g. Rs.26,900.00)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Bundles",
      "settings": {
        "layout_style": "slider",
        "auto_slide": true,
        "slide_interval": 4,
        "show_dots": true
      },
      "blocks": [
        {
          "type": "bundle",
          "settings": {
            "title": "Ultimate Clear Skin Edit",
            "subtitle": "Fight Breakouts. Fade Marks. Stay Clear.",
            "discount_percent": "53",
            "compare_price": "Rs.54,400.00",
            "sale_price": "Rs.26,900.00"
          }
        },
        {
          "type": "bundle",
          "settings": {
            "title": "Clear Skin Kit: Acne Essentials",
            "subtitle": "Leave Hormonal Acne Behind and Get Clear Skin",
            "discount_percent": "36",
            "compare_price": "Rs.37,400.00",
            "sale_price": "Rs.21,300.00"
          }
        },
        {
          "type": "bundle",
          "settings": {
            "title": "The Fresh Face Edit",
            "subtitle": "Your First Routine, Done Right",
            "discount_percent": "30",
            "compare_price": "Rs.22,400.00",
            "sale_price": "Rs.15,600.00"
          }
        }
      ]
    }
  ]
}
{% endschema %}
