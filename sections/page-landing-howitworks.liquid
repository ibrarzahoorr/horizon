<section class="page-landing__how-it-works" style="background-color: {{ section.settings.bg_color }};">
  <div class="landing-hiw__container f rel">
    <div class="landing-hiw__image">
      <img class="desktop-image lazyload" data-src="{{ section.settings.desktop_image | img_url: '1000x' }}" data-srcset="{{ section.settings.desktop_image | img_url: '2000x' }} 2x">
      <img class="mobile-image lazyload" data-src="{{ section.settings.mobile_image | img_url: '400x' }}" data-srcset="{{ section.settings.mobile_image | img_url: '800x' }} 2x">
    </div>
    <div class="landing-hiw__content container--ms f jcc px2">
      {% if section.settings.heading != blank %}
        <h2 class="serif al mt0">{{ section.settings.heading }}</h2>
        <ol class="landing-hiw__bullets">
          {% for block in section.blocks %}
            <li>{{ block.settings.text }}</li>
          {% endfor %}
        </ol>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "How it Works",
    "settings": [
      {
        "type": "header",
        "content": "Settings"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }
    ],
    "blocks": [
      {
        "type": "step",
        "name": "Step",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          }
        ]
      }
    ]
  }
{% endschema %}