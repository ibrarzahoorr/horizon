  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "General colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#000",
        "info": "Used for text links, and primary buttons"
      },
      {
        "type": "color",
        "id": "color_body_text",
        "label": "Text color",
        "default": "#000",
        "info": "Color used for content and paragraph text"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social sharing options"
      },
      {
        "type": "checkbox",
        "id": "social_sharing_blog",
