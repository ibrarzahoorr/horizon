  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_notes_enable",
        "label": "Enable cart notes",
        "default": true
      }
    ]
  },
  {
    "name": "Free Shipping Bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_free_shipping_bar",
        "label": "Show Bar",
        "default": true
      },
      {
        "type": "range",
        "id": "minimum_spend",
        "label": "Minimum spend",
        "unit": "$",
        "min": 10,
        "max": 100,
        "step": 1,
        "default": 50
      },
      {
        "type": "text",
        "id": "text_1",
        "label": "Text 1",
        "default": "You are $[number] away from free shipping",
        "info": "Default: You are $[number] away from free shipping"
      },
      {
        "type": "text",
        "id": "text_2",
        "label": "Text 2",
        "default": "Your order qualifies free shipping"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  },
  {
    "name": "Extended Javascript",
    "settings": [
      {
        "type": "textarea",
        "id": "js_extend",
        "label": "Additional Global Javascript"
      }
    ]
  },
  {
    "name": "Discount Code",
    "settings": [
      {
        "type": "checkbox",
        "id": "discount_code_enable",
        "label": "Enable Discount Code",
        "default": false
      },
      {
        "type": "richtext",
        "id": "discount_code_text",
        "label": "Discount Code Copy"
      }
    ]
  }
