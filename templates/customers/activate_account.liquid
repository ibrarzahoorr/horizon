
<div class='account-register fill-x fill-y account-wrapper bg-p ac f aic jcc'>
  <div class='outer x'>
    <div class='account-dialog bg-w px2 mha'>
      <h1 class='serif'>{{ 'customer.activate_account.title' | t }}</h1>
      <p class='mb2'>{{ 'customer.activate_account.subtext' | t }}</p>

      {% form 'activate_customer_password' %}
        {{ form.errors | default_errors }}

        {%
          include 'form-input-text' with
          placeholder: 'Password',
          name: 'customer[password]',
          type: 'password',
          className: 'mb1',
          id: 'CustomerPassword'
        %}


        {%
          include 'form-input-text' with
          placeholder: 'Confirm Password',
          name: 'customer[password_confirmation]',
          type: 'password',
          className: 'mb1',
          id: 'CustomerPasswordConfirmation'
        %}

        <div class='mt2'>
          <button type='submit' class='btn btn__blue caps bold' role='button'>Activate Account</button>
        </div>



        <!-- <input type="submit" class="btn" value="{{ 'customer.activate_account.submit' | t }}">
        <input type="submit" class="btn btn--secondary" name="decline" value="{{ 'customer.activate_account.cancel' | t }}"> -->
      {% endform %}
    </div>
  </div>
</div>
