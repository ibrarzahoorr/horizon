<div class='fill-x filly account-wrapper bg-p f aic jcc'>
  <div class='container--l mha px1'>
    <section class='account-home outer mt2 pt2'>
      <div class="form-reset-password">
        {% form 'reset_customer_password' %}

          <h1>{{ 'customer.reset_password.title' | t }}</h1>

          <p>{{ 'customer.reset_password.subtext' | t: email: email }}</p>

          {{ form.errors | default_errors }}

          <div class='account-address__form__field x mb1'>
            {%
            include 'form-input-text' with
            label: 'Password',
            id: 'ResetPassword',
            placeholder: 'Password',
            name: 'customer[password]',
            type: 'password',
            className: 'mb1'
            %}
          </div>

          <div class='account-address__form__field x mb1'>
            {%
            include 'form-input-text' with
            label: 'Confirm Password',
            id: 'PasswordConfirmation',
            placeholder: 'Confirm Password',
            name: 'customer[password_confirmation]',
            type: 'password',
            className: 'mb1'
            %}
          </div>
          
          <div class='mt2'>
            <button type='submit' class='btn btn__blue caps bold' role='button'>{{ 'customer.reset_password.submit' | t }}</button>
          </div>
        {% endform %}
      </div>
    </section>
  </div>
</div>